---
/**
 * Shared shell for /dev/* engine demos. Element ids are plain (`error`, `fps`,
 * `debug-info`) so mountScene and debug scripts bind without a leading `#`.
 */
import HomeLink from "../ui/HomeLink.astro";
import Layout from "../layouts/Layout.astro";

interface Props {
  /** Debug panel placement. */
  panel?: "none" | "bottom" | "dock" | "rail" | "hidden-dock";
  /** Tag used for the debug-info node. */
  debugAs?: "p" | "pre";
  title?: string;
}

const {
  panel = "none",
  debugAs = "p",
  title = "Developer Lab · Marble",
} = Astro.props;

const DebugTag = debugAs;
---

<Layout {title}>
  <HomeLink href="/dev" label="Dev home" />
  <p
    class="absolute left-1/2 top-1/2 z-10 -translate-x-1/2 -translate-y-1/2 text-lg text-rose-500"
    id="error"
  >
  </p>

  {
    panel === "hidden-dock" ? (
      <main class="relative flex size-full items-center justify-center gap-5">
        <div class="relative z-0 size-full flex-2">
          <canvas id="gl-canvas" class="size-full drop-shadow-xl">
            Canvas Not supported
          </canvas>
        </div>
        <div class="relative hidden h-full max-h-[1000px] w-full max-w-md flex-1 rounded-2xl bg-zinc-600/40 px-10 py-5 backdrop-blur">
          <div class="flex w-full items-center justify-between">
            <h1 class="text-2xl font-bold">Debug</h1>
            <p class="z-10 bg-black/80 px-4 py-1 font-mono" id="fps">
              FPS: 0.00
            </p>
          </div>
          <DebugTag id="debug-info" class="mt-6 text-lg leading-10" />
        </div>
      </main>
    ) : (
      <>
        <div class="relative z-0 size-full">
          <canvas id="gl-canvas" class="size-full drop-shadow-xl">
            Canvas Not supported
          </canvas>
        </div>

        {panel === "bottom" && (
          <div class="absolute bottom-0 z-10 flex h-40 w-full flex-col items-start gap-4 bg-zinc-800/40 px-12 py-8 backdrop-blur">
            <h1 class="text-lg font-semibold underline">Debug Info</h1>
            <DebugTag id="debug-info" class="font-mono" />
            <p id="fps">FPS: 0</p>
          </div>
        )}

        {panel === "dock" && (
          <div class="absolute right-10 top-1/2 h-full max-h-[40rem] w-full max-w-sm flex-1 -translate-y-1/2 overflow-scroll rounded-2xl bg-zinc-800/60 px-10 py-8 backdrop-blur">
            <div class="flex w-full items-center justify-between">
              <h1 class="text-2xl font-bold">Debug</h1>
              <p class="z-10 bg-black/80 px-4 py-1 font-mono" id="fps">
                FPS: 0.00
              </p>
            </div>
            <DebugTag id="debug-info" class="mt-6 text-sm leading-10" />
          </div>
        )}

        {panel === "rail" && (
          <div class="absolute right-0 top-0 z-10 flex h-full w-1/3 flex-col items-start gap-4 overflow-y-auto bg-zinc-800/40 px-12 py-8 backdrop-blur">
            <h1 class="text-lg font-semibold underline">Debug Info</h1>
            <DebugTag id="debug-info" class="font-mono" />
            <p id="fps">FPS: 0</p>
          </div>
        )}
      </>
    )
  }
</Layout>
