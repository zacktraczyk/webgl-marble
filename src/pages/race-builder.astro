---
import Layout from "../layouts/Layout.astro";
import Tooltip from "../components/Tooltip.astro";
---

<Layout title="Race Builder · Marbel">
  <main class="min-h-full bg-canvas text-ink lg:h-full lg:overflow-hidden">
    <section
      id="missing-race"
      hidden
      class="mx-auto w-full max-w-7xl px-5 py-28 sm:px-8"
    >
      <h1 class="type-display text-[clamp(2.5rem,7vw,5.5rem)] text-ink-faint">
        Race not found
      </h1>
      <p class="mt-5 text-sm text-ink-dim">
        It may have been deleted from this browser.
      </p>
      <a href="/" class="pill pill-primary mt-8 text-sm">Return to library</a>
    </section>

    <section
      id="race-builder"
      hidden
      class="mx-auto w-full max-w-7xl px-5 pb-24 pt-14 sm:px-8 sm:pt-20 lg:h-full lg:pb-0 lg:pt-0"
    >
      <div
        class="grid gap-12 lg:h-full lg:grid-cols-[minmax(0,24rem)_minmax(0,34rem)] lg:justify-center lg:gap-16"
      >
        <div class="min-w-0 lg:self-start lg:pt-20">
          <a href="/" class="text-sm font-semibold text-ink-dim hover:text-ink"
            >← Library</a
          >
          <label for="race-name" class="sr-only">Race name</label>
          <textarea
            id="race-name"
            maxlength="80"
            rows="1"
            class="type-display mt-6 block w-full resize-none overflow-hidden border-0 bg-transparent p-0 text-[clamp(3rem,6vw,4.5rem)] text-ink caret-brand [text-shadow:0.08em_0.09em_0_var(--color-shadow)] placeholder:text-ink-faint focus:outline-none"
            placeholder="Untitled race"></textarea>
          <a id="play-race" class="pill pill-play mt-8 text-sm">Play race</a>

          <aside class="card mt-10 p-6">
            <p class="text-xs font-semibold text-ink-faint">Setup</p>
            <div class="mt-5 flex items-center justify-between gap-4">
              <div>
                <p class="text-sm font-bold text-ink">Starting teams</p>
                <p class="mt-1 text-xs leading-4 text-ink-dim">
                  100 marbles each · one out per leg
                </p>
              </div>
              <div class="flex items-center rounded-full bg-canvas">
                <button
                  id="marbles-minus"
                  type="button"
                  aria-label="Remove a starting team"
                  data-tooltip="Remove a starting team"
                  class="size-9 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
                  >−</button
                >
                <output
                  id="marble-count"
                  class="min-w-9 text-center text-sm font-bold tabular-nums text-ink"
                  >4</output
                >
                <button
                  id="marbles-plus"
                  type="button"
                  aria-label="Add a starting team"
                  data-tooltip="Add a starting team"
                  class="size-9 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
                  >+</button
                >
              </div>
            </div>
            <details class="group mt-6 border-t border-line pt-4">
              <summary
                class="flex cursor-pointer list-none items-center justify-between text-xs font-semibold text-ink-dim hover:text-ink"
              >
                Advanced
                <span
                  class="text-ink-faint transition-transform group-open:rotate-90"
                  >→</span
                >
              </summary>
              <label
                class="mt-4 block text-sm font-bold text-ink"
                for="release-speed">Release interval</label
              >
              <div class="mt-3 flex items-center gap-3">
                <input
                  id="release-speed"
                  type="range"
                  min="20"
                  max="240"
                  step="20"
                  class="w-full accent-brand"
                />
                <output
                  id="release-speed-output"
                  class="w-16 text-right text-xs tabular-nums text-ink-dim"
                ></output>
              </div>
            </details>
          </aside>
        </div>

        <section
          id="race-legs"
          class="min-w-0 lg:overflow-y-auto lg:overscroll-y-contain lg:px-6 lg:pb-16 lg:pt-20"
        >
          <div class="flex items-baseline justify-between gap-4">
            <div class="flex items-baseline gap-4">
              <h2 class="type-display text-2xl text-ink sm:text-3xl">
                Race legs
              </h2>
              <span
                id="leg-count"
                class="text-sm font-medium tabular-nums text-ink-faint"></span>
            </div>
            <p
              id="leg-guidance"
              class="text-xs font-semibold text-ink-dim"
              aria-live="polite"
            >
            </p>
          </div>

          <p id="leg-move-status" class="sr-only" role="status"></p>
          <ol id="leg-list" class="mt-8 flex flex-col gap-6"></ol>

          <div class="mt-10 flex justify-center gap-3">
            <button
              id="complete-race"
              type="button"
              class="pill pill-ghost text-sm">Auto-fill legs</button
            >
            <button id="add-leg" type="button" class="pill pill-primary text-sm"
              >Add leg</button
            >
          </div>
        </section>
      </div>
    </section>
    <Tooltip />
  </main>

  <template id="leg-template">
    <li>
      <div class="group relative">
        <a
          data-edit-leg
          class="card relative block overflow-hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-guide"
        >
          <canvas data-leg-thumbnail class="block aspect-[16/9] w-full"
          ></canvas>
        </a>
        <button
          data-drag-leg
          type="button"
          draggable="true"
          data-tooltip="Drag to reorder"
          class="absolute left-3 top-3 z-10 flex cursor-grab select-none items-center gap-1.5 rounded-full bg-canvas/90 px-2.5 py-1 text-xs font-bold tabular-nums text-ink-dim backdrop-blur hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-guide active:cursor-grabbing"
        >
          <svg
            class="size-3 text-ink-faint"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <circle cx="9" cy="5.5" r="2"></circle>
            <circle cx="15" cy="5.5" r="2"></circle>
            <circle cx="9" cy="12" r="2"></circle>
            <circle cx="15" cy="12" r="2"></circle>
            <circle cx="9" cy="18.5" r="2"></circle>
            <circle cx="15" cy="18.5" r="2"></circle>
          </svg>
          <span data-leg-number></span>
        </button>
        <div
          class="absolute right-3 top-3 z-10 flex gap-1.5 opacity-0 transition-opacity group-focus-within:opacity-100 group-hover:opacity-100"
        >
          <button
            data-duplicate-leg
            type="button"
            aria-label="Duplicate leg"
            data-tooltip="Duplicate leg"
            class="grid size-8 place-items-center rounded-full bg-canvas/70 text-ink-dim backdrop-blur hover:bg-canvas hover:text-ink"
          >
            <svg
              class="size-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="12" height="12" rx="2.5"></rect>
              <path
                d="M5 15H4.5A1.5 1.5 0 0 1 3 13.5v-9A1.5 1.5 0 0 1 4.5 3h9A1.5 1.5 0 0 1 15 4.5V5"
              ></path>
            </svg>
          </button>
          <button
            data-delete-leg
            type="button"
            aria-label="Delete leg"
            data-tooltip="Delete leg"
            class="grid size-8 place-items-center rounded-full bg-canvas/70 text-ink-dim backdrop-blur hover:bg-canvas hover:text-red-400"
          >
            <svg
              class="size-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M3 6h18"></path>
              <path
                d="M19 6v13.5A1.5 1.5 0 0 1 17.5 21h-11A1.5 1.5 0 0 1 5 19.5V6"
              ></path>
              <path d="M8 6V4.5A1.5 1.5 0 0 1 9.5 3h5A1.5 1.5 0 0 1 16 4.5V6"
              ></path>
            </svg>
          </button>
        </div>
      </div>
    </li>
  </template>
</Layout>

<script>
  import {
    MAX_RACE_PARTICIPANTS,
    RaceRepository,
    createDefaultLeg,
    createDefaultParticipants,
    createLocalId,
    isRacePlayable,
    renderLevelThumbnail,
    requiredLegCount,
  } from "../races";
  import type { RaceDocument, RaceLegDocument } from "../races";
  import { attachTooltip } from "../components/tooltip";

  attachTooltip(document.body);
  const repository = new RaceRepository();
  const params = new URLSearchParams(window.location.search);
  const raceId = params.get("race") ?? "";
  let race: RaceDocument | null = repository.get(raceId);

  const missing = document.querySelector<HTMLElement>("#missing-race");
  const builder = document.querySelector<HTMLElement>("#race-builder");
  const nameInput = document.querySelector<HTMLTextAreaElement>("#race-name");
  const playLink = document.querySelector<HTMLAnchorElement>("#play-race");
  const marbleCount =
    document.querySelector<HTMLOutputElement>("#marble-count");
  const marblesMinus =
    document.querySelector<HTMLButtonElement>("#marbles-minus");
  const marblesPlus =
    document.querySelector<HTMLButtonElement>("#marbles-plus");
  const releaseSpeed =
    document.querySelector<HTMLInputElement>("#release-speed");
  const releaseSpeedOutput = document.querySelector<HTMLOutputElement>(
    "#release-speed-output"
  );
  const legCount = document.querySelector<HTMLElement>("#leg-count");
  const legGuidance = document.querySelector<HTMLElement>("#leg-guidance");
  const legList = document.querySelector<HTMLOListElement>("#leg-list");
  const legTemplate =
    document.querySelector<HTMLTemplateElement>("#leg-template");
  const addLegButton = document.querySelector<HTMLButtonElement>("#add-leg");
  const completeRaceButton =
    document.querySelector<HTMLButtonElement>("#complete-race");
  const legMoveStatus = document.querySelector<HTMLElement>("#leg-move-status");

  let draggedItem: HTMLElement | null = null;
  let pendingFocusLegId: string | null = null;

  const editLegUrl = (legId: string) =>
    `/leg-builder?race=${encodeURIComponent(raceId)}&leg=${encodeURIComponent(legId)}`;

  const saveRace = (next: RaceDocument) => {
    race = repository.save(next);
    render();
  };

  const fitNameInput = () => {
    if (!nameInput) return;
    nameInput.style.height = "auto";
    nameInput.style.height = `${nameInput.scrollHeight}px`;
  };

  const render = () => {
    if (
      !race ||
      !nameInput ||
      !playLink ||
      !marbleCount ||
      !marblesMinus ||
      !marblesPlus ||
      !releaseSpeed ||
      !releaseSpeedOutput ||
      !legCount ||
      !legGuidance ||
      !legList ||
      !legTemplate ||
      !addLegButton ||
      !completeRaceButton
    ) {
      return;
    }
    if (document.activeElement !== nameInput) nameInput.value = race.name;
    fitNameInput();
    marbleCount.value = `${race.participants.length}`;
    marblesMinus.disabled = race.participants.length <= 2;
    marblesPlus.disabled = race.participants.length >= MAX_RACE_PARTICIPANTS;
    releaseSpeed.value = `${race.releaseIntervalMs}`;
    releaseSpeedOutput.value = `${race.releaseIntervalMs} ms`;

    const needed = requiredLegCount(race);
    const difference = needed - race.legs.length;
    legCount.textContent = `${race.legs.length} / ${needed}`;
    legGuidance.textContent =
      difference === 0
        ? "Ready to play"
        : difference > 0
          ? `Add ${difference} ${difference === 1 ? "leg" : "legs"}`
          : `Remove ${Math.abs(difference)} ${Math.abs(difference) === 1 ? "leg" : "legs"}`;
    legGuidance.className = `text-xs font-semibold ${difference === 0 ? "text-green-400" : "text-red-400"}`;
    addLegButton.hidden = difference <= 0;
    completeRaceButton.hidden = difference === 0;

    const playable = isRacePlayable(race);
    if (playable) {
      playLink.href = `/race?race=${encodeURIComponent(race.id)}`;
      playLink.removeAttribute("data-tooltip");
    } else {
      playLink.removeAttribute("href");
      playLink.dataset.tooltip =
        difference > 0
          ? `Add ${difference} ${difference === 1 ? "leg" : "legs"} to play`
          : `Remove ${Math.abs(difference)} ${Math.abs(difference) === 1 ? "leg" : "legs"} to play`;
    }
    playLink.setAttribute("aria-disabled", `${!playable}`);
    playLink.classList.toggle("opacity-40", !playable);
    playLink.classList.toggle("cursor-not-allowed", !playable);
    playLink.classList.toggle("hover:transform-none", !playable);

    legList.replaceChildren();
    let handleToFocus: HTMLButtonElement | null = null;
    const startingTeams = race.participants.length;
    race.legs.forEach((leg, index) => {
      const fragment = legTemplate.content.cloneNode(true) as DocumentFragment;
      const item = fragment.querySelector<HTMLElement>("li");
      const number = fragment.querySelector<HTMLElement>("[data-leg-number]");
      const thumbnail = fragment.querySelector<HTMLCanvasElement>(
        "[data-leg-thumbnail]"
      );
      const duplicate = fragment.querySelector<HTMLButtonElement>(
        "[data-duplicate-leg]"
      );
      const remove =
        fragment.querySelector<HTMLButtonElement>("[data-delete-leg]");
      const edit = fragment.querySelector<HTMLAnchorElement>("[data-edit-leg]");
      const handle =
        fragment.querySelector<HTMLButtonElement>("[data-drag-leg]");
      if (
        !item ||
        !number ||
        !thumbnail ||
        !duplicate ||
        !remove ||
        !edit ||
        !handle
      )
        return;

      number.textContent = `${index + 1}`.padStart(2, "0");
      edit.href = editLegUrl(leg.id);
      edit.setAttribute("aria-label", `Edit “${leg.name}”`);
      handle.setAttribute(
        "aria-label",
        `Reorder “${leg.name}”, position ${index + 1} of ${race!.legs.length}. Press arrow keys to move.`
      );
      if (leg.id === pendingFocusLegId) handleToFocus = handle;
      handle.addEventListener("keydown", (event) => {
        const offset =
          event.key === "ArrowUp" ? -1 : event.key === "ArrowDown" ? 1 : 0;
        if (!offset || !race) return;
        event.preventDefault();
        const from = race.legs.findIndex((candidate) => candidate.id === leg.id);
        const to = from + offset;
        if (from < 0 || to < 0 || to >= race.legs.length) return;
        race = repository.moveLeg(race.id, leg.id, to);
        pendingFocusLegId = leg.id;
        if (legMoveStatus) {
          legMoveStatus.textContent = `“${leg.name}” moved to position ${to + 1} of ${race.legs.length}.`;
        }
        render();
      });
      handle.addEventListener("dragstart", (event) => {
        if (!event.dataTransfer) return;
        draggedItem = item;
        event.dataTransfer.effectAllowed = "move";
        event.dataTransfer.setData("text/plain", leg.id);
        const rect = item.getBoundingClientRect();
        event.dataTransfer.setDragImage(
          item,
          event.clientX - rect.left,
          event.clientY - rect.top
        );
        // Fade after the browser captures the drag image, not before.
        requestAnimationFrame(() => item.classList.add("opacity-40"));
      });
      handle.addEventListener("dragend", (event) => {
        draggedItem = null;
        item.classList.remove("opacity-40");
        if (!race) return;
        const to = Array.from(legList.children).indexOf(item);
        const from = race.legs.findIndex((candidate) => candidate.id === leg.id);
        if (event.dataTransfer?.dropEffect !== "none" && to >= 0 && to !== from) {
          race = repository.moveLeg(race.id, leg.id, to);
        }
        // Re-render even when nothing moved to undo any live preview reordering.
        render();
      });
      duplicate.addEventListener("click", () => {
        if (!race || race.legs.length >= MAX_RACE_PARTICIPANTS - 1) return;
        const duplicateName = `${leg.name} copy`;
        const copy: RaceLegDocument = {
          ...structuredClone(leg),
          id: createLocalId(),
          name: duplicateName,
          level: { ...structuredClone(leg.level), name: duplicateName },
        };
        race = repository.addLeg(race.id, copy, index + 1);
        render();
      });
      remove.addEventListener("click", () => {
        if (!race || !window.confirm(`Delete “${leg.name}”?`)) return;
        race = repository.deleteLeg(race.id, leg.id);
        render();
      });

      legList.append(fragment);
      // One team is eliminated per leg, so later legs race with fewer teams.
      renderLevelThumbnail(thumbnail, leg.level, {
        teamCount: startingTeams - index,
      });
    });
    pendingFocusLegId = null;
    handleToFocus?.focus();
  };

  const setParticipantCount = (nextCount: number) => {
    if (!race || nextCount < 2 || nextCount > MAX_RACE_PARTICIPANTS) return;
    const defaults = createDefaultParticipants(nextCount);
    saveRace({
      ...race,
      participants: defaults.map(
        (participant, index) => race!.participants[index] ?? participant
      ),
    });
  };

  if (!race) {
    if (missing) missing.hidden = false;
    if (playLink) playLink.hidden = true;
  } else {
    if (builder) builder.hidden = false;
    nameInput?.addEventListener("input", fitNameInput);
    nameInput?.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        nameInput.blur();
      }
    });
    nameInput?.addEventListener("change", () => {
      if (!race || !nameInput) return;
      const name = nameInput.value.replace(/\s+/g, " ").trim();
      saveRace({ ...race, name: name || "Untitled race" });
    });
    marblesMinus?.addEventListener(
      "click",
      () => race && setParticipantCount(race.participants.length - 1)
    );
    marblesPlus?.addEventListener(
      "click",
      () => race && setParticipantCount(race.participants.length + 1)
    );
    releaseSpeed?.addEventListener("input", () => {
      if (releaseSpeedOutput && releaseSpeed)
        releaseSpeedOutput.value = `${releaseSpeed.value} ms`;
    });
    releaseSpeed?.addEventListener("change", () => {
      if (!race || !releaseSpeed) return;
      saveRace({ ...race, releaseIntervalMs: Number(releaseSpeed.value) });
    });
    addLegButton?.addEventListener("click", () => {
      if (!race || race.legs.length >= requiredLegCount(race)) return;
      race = repository.addLeg(
        race.id,
        createDefaultLeg({ index: race.legs.length })
      );
      render();
    });
    legList?.addEventListener("dragover", (event) => {
      if (!draggedItem || !legList) return;
      event.preventDefault();
      if (event.dataTransfer) event.dataTransfer.dropEffect = "move";
      const nextSibling = Array.from(legList.children)
        .filter(
          (child): child is HTMLElement =>
            child instanceof HTMLElement && child !== draggedItem
        )
        .find((child) => {
          const rect = child.getBoundingClientRect();
          return event.clientY < rect.top + rect.height / 2;
        });
      if ((nextSibling ?? null) === draggedItem.nextElementSibling) return;
      legList.insertBefore(draggedItem, nextSibling ?? null);
      legList
        .querySelectorAll("[data-leg-number]")
        .forEach((numberBadge, position) => {
          numberBadge.textContent = `${position + 1}`.padStart(2, "0");
        });
    });
    legList?.addEventListener("drop", (event) => event.preventDefault());
    completeRaceButton?.addEventListener("click", () => {
      if (!race) return;
      const needed = requiredLegCount(race);
      if (
        race.legs.length > needed &&
        !window.confirm(
          `Remove the final ${race.legs.length - needed} ${race.legs.length - needed === 1 ? "leg" : "legs"} to match the team count?`
        )
      ) {
        return;
      }
      const next = structuredClone(race);
      next.legs.splice(needed);
      while (next.legs.length < needed) {
        next.legs.push(createDefaultLeg({ index: next.legs.length }));
      }
      saveRace(next);
    });
    render();
  }
</script>
