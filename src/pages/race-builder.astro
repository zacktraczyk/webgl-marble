---
import Layout from "../layouts/Layout.astro";
import Tooltip from "../ui/Tooltip.astro";
import ConfirmDeleteDialog from "../ui/ConfirmDeleteDialog.astro";
---

<Layout title="Race Builder · Marble">
  <main class="min-h-full bg-canvas text-ink lg:h-full lg:overflow-hidden">
    <section
      id="missing-race"
      hidden
      class="mx-auto w-full max-w-7xl px-5 py-28 sm:px-8"
    >
      <h1
        class="font-extrabold tracking-[-0.03em] leading-[0.92] text-[clamp(2.5rem,7vw,5.5rem)] text-ink-faint"
      >
        Race not found
      </h1>
      <p class="mt-5 text-sm text-ink-dim">
        It may have been deleted from this browser.
      </p>
      <a href="/" class="pill pill-primary mt-8 text-sm">Return to library</a>
    </section>

    <section
      id="race-builder"
      hidden
      class="mx-auto w-full max-w-7xl px-5 pb-24 pt-14 sm:px-8 sm:pt-20 lg:h-full lg:pb-0 lg:pt-0"
    >
      <div
        class="grid gap-12 lg:h-full lg:grid-cols-[minmax(0,24rem)_minmax(0,34rem)] lg:justify-center lg:gap-16"
      >
        <div class="min-w-0 lg:self-start lg:pt-20">
          <a href="/" class="text-sm font-semibold text-ink-dim hover:text-ink"
            >← Library</a
          >
          <label for="race-name" class="sr-only">Race name</label>
          <textarea
            id="race-name"
            maxlength="80"
            rows="1"
            class="mt-6 block w-full resize-none overflow-hidden border-0 bg-transparent p-0 font-extrabold tracking-[-0.03em] leading-[0.92] text-[clamp(3rem,6vw,4.5rem)] text-ink caret-brand [text-shadow:0.08em_0.09em_0_var(--color-stamp)] placeholder:text-ink-faint focus:outline-none"
            placeholder="Untitled race"></textarea>
          <label for="race-description" class="sr-only">Race description</label>
          <textarea
            id="race-description"
            maxlength="500"
            rows="1"
            class="mt-4 block w-full resize-none overflow-hidden border-0 bg-transparent p-0 text-lg leading-7 text-ink-dim caret-brand placeholder:text-ink-faint focus:outline-none"
            placeholder="Add a short description…"></textarea>
          <a id="play-race" class="pill pill-play mt-10 text-sm">Play race</a>
        </div>

        <section
          id="race-legs"
          class="min-w-0 lg:overflow-y-auto lg:overscroll-y-contain lg:px-6 lg:pb-16"
        >
          <div id="legs-divider" class="h-0 lg:mt-14"></div>

          <div
            id="legs-header"
            class="sticky top-0 z-20 flex items-center justify-between gap-4 border-b border-transparent bg-canvas pb-4 pt-6 transition-colors duration-200"
          >
            <div class="flex items-baseline gap-4">
              <h2
                class="font-extrabold tracking-[-0.03em] leading-[0.92] text-2xl text-ink sm:text-3xl"
              >
                Race legs
              </h2>
              <span
                id="leg-count"
                class="text-sm font-medium tabular-nums text-ink-faint"></span>
            </div>
            <div class="flex items-center gap-2">
              <p
                id="setup-warning"
                hidden
                class="flex items-center gap-1.5 rounded-full bg-amber-400/10 px-3 py-1.5 text-xs font-semibold text-amber-300"
                aria-live="polite"
              >
                <!-- lucide: triangle-alert -->
                <svg
                  class="size-3.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"
                  ></path>
                  <path d="M12 9v4"></path>
                  <path d="M12 17h.01"></path>
                </svg>
                <span id="setup-warning-text"></span>
              </p>
              <div class="relative">
                <button
                  id="setup-toggle"
                  type="button"
                  aria-haspopup="dialog"
                  aria-expanded="false"
                  class="flex cursor-pointer items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-semibold text-ink-dim ring-2 ring-inset ring-line transition-colors hover:bg-raise hover:text-ink"
                >
                  <!-- lucide: settings-2 -->
                  <svg
                    class="size-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M14 17H5"></path>
                    <path d="M19 7h-9"></path>
                    <circle cx="17" cy="17" r="3"></circle>
                    <circle cx="7" cy="7" r="3"></circle>
                  </svg>
                  <span id="setup-summary-pill"></span>
                </button>
                <div
                  id="setup-popover"
                  role="dialog"
                  aria-label="Race setup"
                  hidden
                  class="popover-drop absolute right-0 top-full z-40 mt-2 w-72 rounded-[1.25rem] bg-panel p-5 shadow-[0_6px_0_var(--color-shadow)]"
                >
                  <div class="flex items-center justify-between gap-4">
                    <p class="text-sm font-bold text-ink">Starting teams</p>
                    <div class="flex items-center rounded-full bg-canvas">
                      <button
                        id="marbles-minus"
                        type="button"
                        aria-label="Remove a starting team"
                        data-tooltip="Remove a team"
                        class="size-9 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
                        >−</button
                      >
                      <output
                        id="marble-count"
                        class="min-w-9 text-center text-sm font-bold tabular-nums text-ink"
                        >4</output
                      >
                      <button
                        id="marbles-plus"
                        type="button"
                        aria-label="Add a starting team"
                        data-tooltip="Add a team"
                        class="size-9 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
                        >+</button
                      >
                    </div>
                  </div>
                  <div class="mt-6">
                    <label
                      class="block text-sm font-bold text-ink"
                      for="marbles-per-team">Starting marbles per team</label
                    >
                    <div class="mt-3 flex items-center gap-3">
                      <input
                        id="marbles-per-team"
                        type="range"
                        min="0"
                        max="13"
                        step="1"
                        class="w-full accent-cyan-400"
                      />
                      <output
                        id="marbles-per-team-output"
                        class="w-16 text-right text-xs tabular-nums text-ink-dim"
                      ></output>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <p id="leg-move-status" class="sr-only" role="status"></p>
          <ol id="leg-list" class="mt-4 flex flex-col gap-6"></ol>

          <button
            id="add-leg"
            type="button"
            class="group/add mt-6 flex aspect-[16/9] w-full cursor-pointer flex-col items-center justify-center gap-5 rounded-[1.25rem] border-2 border-dashed border-line px-6 transition-colors hover:border-ink-dim"
          >
            <span
              class="max-w-56 text-balance text-center text-[1.375rem] font-extrabold leading-tight tracking-[-0.01em] text-ink-dim"
              >One leg at a time…</span
            >
            <span
              class="pill pill-primary text-sm group-hover/add:translate-y-0.5 group-hover/add:shadow-[0_2px_0_oklch(58%_0.005_285)]"
            >
              <!-- lucide: plus -->
              <svg
                class="size-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14"></path>
                <path d="M12 5v14"></path>
              </svg>
              Add leg
            </span>
          </button>

          <div class="mt-6 flex justify-center">
            <button
              id="complete-race"
              type="button"
              class="pill pill-ghost text-sm">Auto-fill legs</button
            >
          </div>
        </section>
      </div>
    </section>
    <Tooltip />
  </main>

  <ConfirmDeleteDialog />

  <template id="leg-template">
    <li>
      <div class="group relative">
        <a
          data-edit-leg
          class="relative block overflow-hidden rounded-[1.25rem] bg-panel shadow-[0_6px_0_var(--color-shadow)] focus:outline-none focus-visible:ring-2 focus-visible:ring-guide"
        >
          <canvas data-leg-thumbnail class="block aspect-[16/9] w-full"
          ></canvas>
        </a>
        <button
          data-drag-leg
          type="button"
          draggable="true"
          data-tooltip="Drag to reorder"
          class="absolute left-3 top-3 z-10 flex cursor-grab select-none items-center gap-1.5 rounded-full bg-canvas/90 px-2.5 py-1 text-xs font-bold tabular-nums text-ink-dim backdrop-blur hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-guide active:cursor-grabbing"
        >
          <svg
            class="size-3 text-ink-faint"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <circle cx="9" cy="5.5" r="2"></circle>
            <circle cx="15" cy="5.5" r="2"></circle>
            <circle cx="9" cy="12" r="2"></circle>
            <circle cx="15" cy="12" r="2"></circle>
            <circle cx="9" cy="18.5" r="2"></circle>
            <circle cx="15" cy="18.5" r="2"></circle>
          </svg>
          <span data-leg-number></span>
        </button>
        <div
          class="absolute right-3 top-3 z-10 flex gap-1.5 opacity-0 transition-opacity group-focus-within:opacity-100 group-hover:opacity-100"
        >
          <button
            data-duplicate-leg
            type="button"
            aria-label="Duplicate leg"
            data-tooltip="Duplicate leg"
            class="grid size-8 place-items-center rounded-full bg-canvas/70 text-ink-dim backdrop-blur hover:bg-canvas hover:text-ink"
          >
            <svg
              class="size-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="12" height="12" rx="2.5"></rect>
              <path
                d="M5 15H4.5A1.5 1.5 0 0 1 3 13.5v-9A1.5 1.5 0 0 1 4.5 3h9A1.5 1.5 0 0 1 15 4.5V5"
              ></path>
            </svg>
          </button>
          <button
            data-delete-leg
            type="button"
            aria-label="Delete leg"
            data-tooltip="Delete leg"
            class="grid size-8 place-items-center rounded-full bg-canvas/70 text-ink-dim backdrop-blur hover:bg-canvas hover:text-red-400"
          >
            <svg
              class="size-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M3 6h18"></path>
              <path
                d="M19 6v13.5A1.5 1.5 0 0 1 17.5 21h-11A1.5 1.5 0 0 1 5 19.5V6"
              ></path>
              <path d="M8 6V4.5A1.5 1.5 0 0 1 9.5 3h5A1.5 1.5 0 0 1 16 4.5V6"
              ></path>
            </svg>
          </button>
        </div>
      </div>
    </li>
  </template>
</Layout>

<script>
  import { mountScene } from "../scenes/mount";
  import createScene from "../scenes/race-builder";
  mountScene(createScene());
</script>
