---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Race Builder · Marbel">
  <main class="min-h-full overflow-y-auto bg-zinc-900 text-zinc-100">
    <header
      class="sticky top-0 z-30 border-b border-zinc-800 bg-zinc-900/95 px-5 py-3 backdrop-blur sm:px-8"
    >
      <div
        class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4"
      >
        <a
          href="/"
          class="rounded-md px-3 py-2 text-sm text-zinc-400 hover:bg-zinc-800 hover:text-white"
          >← Library</a
        >
        <div class="flex items-center gap-3">
          <span
            id="save-status"
            class="hidden text-xs text-zinc-500 sm:block"
            aria-live="polite">Saved locally</span
          >
          <a
            id="play-race"
            class="rounded-md bg-zinc-100 px-4 py-2 text-sm font-semibold text-zinc-900 hover:bg-white"
            >Play race</a
          >
        </div>
      </div>
    </header>

    <section
      id="missing-race"
      hidden
      class="mx-auto max-w-xl px-5 py-24 text-center"
    >
      <h1 class="text-2xl font-semibold text-white">Race not found</h1>
      <p class="mt-3 text-sm text-zinc-400">
        It may have been deleted from this browser.
      </p>
      <a
        href="/"
        class="mt-6 inline-block rounded-md bg-zinc-100 px-4 py-2 text-sm font-semibold text-zinc-900"
        >Return to library</a
      >
    </section>

    <section
      id="race-builder"
      hidden
      class="mx-auto w-full max-w-7xl px-5 py-10 sm:px-8 sm:py-14"
    >
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_19rem]">
        <div class="min-w-0">
          <p
            class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500"
          >
            Race builder
          </p>
          <label for="race-name" class="sr-only">Race name</label>
          <input
            id="race-name"
            maxlength="80"
            class="mt-2 w-full border-0 bg-transparent p-0 text-3xl font-semibold tracking-tight text-white placeholder:text-zinc-600 focus:outline-none sm:text-4xl"
            placeholder="Untitled race"
          />
          <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
            Each team starts a leg with 100 marbles. When only one marble is
            left on the track, its team is eliminated.
          </p>
        </div>

        <aside class="rounded-xl border border-zinc-700 bg-zinc-800/70 p-5">
          <p
            class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500"
          >
            Race setup
          </p>
          <div class="mt-4 flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-zinc-200">Starting teams</p>
              <p class="mt-1 text-xs text-zinc-500">
                100 marbles each · one team eliminated per leg
              </p>
            </div>
            <div
              class="flex items-center overflow-hidden rounded-md border border-zinc-600 bg-zinc-900"
            >
              <button
                id="marbles-minus"
                type="button"
                aria-label="Remove a starting team"
                class="size-8 text-zinc-300 hover:bg-zinc-700 disabled:text-zinc-700"
                >−</button
              >
              <output
                id="marble-count"
                class="min-w-8 text-center text-sm font-semibold text-white"
                >4</output
              >
              <button
                id="marbles-plus"
                type="button"
                aria-label="Add a starting team"
                class="size-8 text-zinc-300 hover:bg-zinc-700 disabled:text-zinc-700"
                >+</button
              >
            </div>
          </div>
          <label
            class="mt-5 block text-sm font-medium text-zinc-200"
            for="release-speed">Release interval</label
          >
          <div class="mt-2 flex items-center gap-3">
            <input
              id="release-speed"
              type="range"
              min="20"
              max="240"
              step="20"
              class="w-full accent-zinc-100"
            />
            <output
              id="release-speed-output"
              class="w-14 text-right text-xs tabular-nums text-zinc-400"
            ></output>
          </div>
        </aside>
      </div>

      <section id="race-legs" class="mt-12">
        <div
          class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end"
        >
          <div>
            <div class="flex items-center gap-3">
              <h2 class="text-xl font-semibold text-white">Race legs</h2>
              <span
                id="leg-count"
                class="rounded-full bg-zinc-800 px-2.5 py-1 text-xs text-zinc-400"
              ></span>
            </div>
            <p
              id="leg-guidance"
              class="mt-2 text-sm text-zinc-500"
              aria-live="polite"
            >
            </p>
          </div>
          <div class="flex gap-2">
            <button
              id="complete-race"
              type="button"
              class="rounded-md border border-zinc-600 px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-800 hover:text-white"
              >Auto-fill legs</button
            >
            <button
              id="add-leg"
              type="button"
              class="rounded-md bg-zinc-100 px-4 py-2 text-sm font-semibold text-zinc-900 hover:bg-white"
              >Add leg</button
            >
          </div>
        </div>

        <ol id="leg-list" class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        </ol>
      </section>
    </section>
  </main>

  <template id="leg-template">
    <li
      class="group relative overflow-hidden rounded-xl border border-zinc-700 bg-zinc-800/70"
    >
      <span
        data-leg-number
        class="absolute left-3 top-3 z-10 rounded-full border border-zinc-600 bg-zinc-900/90 px-2.5 py-1 text-[11px] font-semibold text-zinc-200 backdrop-blur"
      ></span>
      <canvas
        data-leg-thumbnail
        class="block aspect-[16/9] w-full border-b border-zinc-700 bg-zinc-950"
      ></canvas>
      <div class="p-4">
        <label
          class="text-[10px] font-semibold uppercase tracking-[0.16em] text-zinc-500"
          >Leg name</label
        >
        <input
          data-leg-name
          maxlength="60"
          class="mt-1 w-full rounded-md border border-transparent bg-transparent px-0 py-1 font-medium text-white focus:border-zinc-600 focus:bg-zinc-900 focus:px-2 focus:outline-none"
        />
        <div
          class="mt-4 flex items-center justify-between gap-3 border-t border-zinc-700 pt-4"
        >
          <div class="flex items-center gap-1">
            <button
              data-move-back
              type="button"
              aria-label="Move leg earlier"
              class="size-8 rounded-md text-zinc-400 hover:bg-zinc-700 hover:text-white disabled:text-zinc-700"
              >←</button
            >
            <button
              data-move-forward
              type="button"
              aria-label="Move leg later"
              class="size-8 rounded-md text-zinc-400 hover:bg-zinc-700 hover:text-white disabled:text-zinc-700"
              >→</button
            >
          </div>
          <div class="flex items-center gap-1">
            <button
              data-duplicate-leg
              type="button"
              class="rounded-md px-2 py-1.5 text-xs text-zinc-400 hover:bg-zinc-700 hover:text-white"
              >Duplicate</button
            >
            <button
              data-delete-leg
              type="button"
              class="rounded-md px-2 py-1.5 text-xs text-zinc-500 hover:bg-zinc-700 hover:text-rose-300"
              >Delete</button
            >
            <a
              data-edit-leg
              class="rounded-md bg-zinc-100 px-3 py-1.5 text-xs font-semibold text-zinc-900 hover:bg-white"
              >Edit leg</a
            >
          </div>
        </div>
      </div>
    </li>
  </template>
</Layout>

<script>
  import {
    MAX_RACE_PARTICIPANTS,
    RaceRepository,
    createDefaultLeg,
    createDefaultParticipants,
    createLocalId,
    isRacePlayable,
    renderLevelThumbnail,
    requiredLegCount,
  } from "../races";
  import type { RaceDocument, RaceLegDocument } from "../races";

  const repository = new RaceRepository();
  const params = new URLSearchParams(window.location.search);
  const raceId = params.get("race") ?? "";
  let race: RaceDocument | null = repository.get(raceId);

  const missing = document.querySelector<HTMLElement>("#missing-race");
  const builder = document.querySelector<HTMLElement>("#race-builder");
  const nameInput = document.querySelector<HTMLInputElement>("#race-name");
  const playLink = document.querySelector<HTMLAnchorElement>("#play-race");
  const saveStatus = document.querySelector<HTMLElement>("#save-status");
  const marbleCount =
    document.querySelector<HTMLOutputElement>("#marble-count");
  const marblesMinus =
    document.querySelector<HTMLButtonElement>("#marbles-minus");
  const marblesPlus =
    document.querySelector<HTMLButtonElement>("#marbles-plus");
  const releaseSpeed =
    document.querySelector<HTMLInputElement>("#release-speed");
  const releaseSpeedOutput = document.querySelector<HTMLOutputElement>(
    "#release-speed-output"
  );
  const legCount = document.querySelector<HTMLElement>("#leg-count");
  const legGuidance = document.querySelector<HTMLElement>("#leg-guidance");
  const legList = document.querySelector<HTMLOListElement>("#leg-list");
  const legTemplate =
    document.querySelector<HTMLTemplateElement>("#leg-template");
  const addLegButton = document.querySelector<HTMLButtonElement>("#add-leg");
  const completeRaceButton =
    document.querySelector<HTMLButtonElement>("#complete-race");

  const editLegUrl = (legId: string) =>
    `/level-builder?race=${encodeURIComponent(raceId)}&leg=${encodeURIComponent(legId)}`;

  const showSaved = () => {
    if (!saveStatus) return;
    saveStatus.textContent = "Saved locally";
  };

  const saveRace = (next: RaceDocument) => {
    race = repository.save(next);
    showSaved();
    render();
  };

  const render = () => {
    if (
      !race ||
      !nameInput ||
      !playLink ||
      !marbleCount ||
      !marblesMinus ||
      !marblesPlus ||
      !releaseSpeed ||
      !releaseSpeedOutput ||
      !legCount ||
      !legGuidance ||
      !legList ||
      !legTemplate ||
      !addLegButton ||
      !completeRaceButton
    ) {
      return;
    }
    if (document.activeElement !== nameInput) nameInput.value = race.name;
    marbleCount.value = `${race.participants.length}`;
    marblesMinus.disabled = race.participants.length <= 2;
    marblesPlus.disabled = race.participants.length >= MAX_RACE_PARTICIPANTS;
    releaseSpeed.value = `${race.releaseIntervalMs}`;
    releaseSpeedOutput.value = `${race.releaseIntervalMs} ms`;

    const needed = requiredLegCount(race);
    const difference = needed - race.legs.length;
    legCount.textContent = `${race.legs.length} of ${needed}`;
    legGuidance.textContent =
      difference === 0
        ? "Ready to play — every leg will eliminate one team."
        : difference > 0
          ? `Add ${difference} more ${difference === 1 ? "leg" : "legs"} to finish with one winner.`
          : `Remove ${Math.abs(difference)} ${Math.abs(difference) === 1 ? "leg" : "legs"}; this race has more legs than eliminations.`;
    legGuidance.className = `mt-2 text-sm ${difference === 0 ? "text-emerald-300" : "text-amber-300"}`;
    addLegButton.disabled = race.legs.length >= MAX_RACE_PARTICIPANTS - 1;
    addLegButton.classList.toggle("opacity-40", addLegButton.disabled);
    completeRaceButton.hidden = difference === 0;

    const playable = isRacePlayable(race);
    playLink.href = playable
      ? `/race?race=${encodeURIComponent(race.id)}`
      : "#race-legs";
    playLink.textContent = playable ? "Play race" : "Finish setup";
    playLink.setAttribute("aria-disabled", `${!playable}`);

    legList.replaceChildren();
    race.legs.forEach((leg, index) => {
      const fragment = legTemplate.content.cloneNode(true) as DocumentFragment;
      const item = fragment.querySelector<HTMLElement>("li");
      const number = fragment.querySelector<HTMLElement>("[data-leg-number]");
      const thumbnail = fragment.querySelector<HTMLCanvasElement>(
        "[data-leg-thumbnail]"
      );
      const legName =
        fragment.querySelector<HTMLInputElement>("[data-leg-name]");
      const moveBack =
        fragment.querySelector<HTMLButtonElement>("[data-move-back]");
      const moveForward = fragment.querySelector<HTMLButtonElement>(
        "[data-move-forward]"
      );
      const duplicate = fragment.querySelector<HTMLButtonElement>(
        "[data-duplicate-leg]"
      );
      const remove =
        fragment.querySelector<HTMLButtonElement>("[data-delete-leg]");
      const edit = fragment.querySelector<HTMLAnchorElement>("[data-edit-leg]");
      if (
        !item ||
        !number ||
        !thumbnail ||
        !legName ||
        !moveBack ||
        !moveForward ||
        !duplicate ||
        !remove ||
        !edit
      )
        return;

      number.textContent = `Leg ${index + 1}`;
      legName.value = leg.name;
      moveBack.disabled = index === 0;
      moveForward.disabled = index === race!.legs.length - 1;
      edit.href = editLegUrl(leg.id);
      legName.addEventListener("change", () => {
        if (!race) return;
        const value = legName.value.trim() || `Leg ${index + 1}`;
        const updated: RaceLegDocument = {
          ...leg,
          name: value,
          level: { ...leg.level, name: value },
        };
        race = repository.saveLeg(race.id, updated);
        render();
      });
      moveBack.addEventListener("click", () => {
        if (!race) return;
        race = repository.moveLeg(race.id, leg.id, index - 1);
        render();
      });
      moveForward.addEventListener("click", () => {
        if (!race) return;
        race = repository.moveLeg(race.id, leg.id, index + 1);
        render();
      });
      duplicate.addEventListener("click", () => {
        if (!race || race.legs.length >= MAX_RACE_PARTICIPANTS - 1) return;
        const duplicateName = `${leg.name} copy`;
        const copy: RaceLegDocument = {
          ...structuredClone(leg),
          id: createLocalId(),
          name: duplicateName,
          level: { ...structuredClone(leg.level), name: duplicateName },
        };
        race = repository.addLeg(race.id, copy, index + 1);
        render();
      });
      remove.addEventListener("click", () => {
        if (!race || !window.confirm(`Delete “${leg.name}”?`)) return;
        race = repository.deleteLeg(race.id, leg.id);
        render();
      });

      legList.append(fragment);
      renderLevelThumbnail(thumbnail, leg.level);
    });
  };

  const setParticipantCount = (nextCount: number) => {
    if (!race || nextCount < 2 || nextCount > MAX_RACE_PARTICIPANTS) return;
    const defaults = createDefaultParticipants(nextCount);
    saveRace({
      ...race,
      participants: defaults.map(
        (participant, index) => race!.participants[index] ?? participant
      ),
    });
  };

  if (!race) {
    if (missing) missing.hidden = false;
    if (playLink) playLink.hidden = true;
  } else {
    if (builder) builder.hidden = false;
    nameInput?.addEventListener("change", () => {
      if (!race || !nameInput) return;
      saveRace({ ...race, name: nameInput.value.trim() || "Untitled race" });
    });
    marblesMinus?.addEventListener(
      "click",
      () => race && setParticipantCount(race.participants.length - 1)
    );
    marblesPlus?.addEventListener(
      "click",
      () => race && setParticipantCount(race.participants.length + 1)
    );
    releaseSpeed?.addEventListener("input", () => {
      if (releaseSpeedOutput && releaseSpeed)
        releaseSpeedOutput.value = `${releaseSpeed.value} ms`;
    });
    releaseSpeed?.addEventListener("change", () => {
      if (!race || !releaseSpeed) return;
      saveRace({ ...race, releaseIntervalMs: Number(releaseSpeed.value) });
    });
    addLegButton?.addEventListener("click", () => {
      if (!race || race.legs.length >= MAX_RACE_PARTICIPANTS - 1) return;
      race = repository.addLeg(
        race.id,
        createDefaultLeg({ index: race.legs.length })
      );
      render();
    });
    completeRaceButton?.addEventListener("click", () => {
      if (!race) return;
      const needed = requiredLegCount(race);
      if (
        race.legs.length > needed &&
        !window.confirm(
          `Remove the final ${race.legs.length - needed} ${race.legs.length - needed === 1 ? "leg" : "legs"} to match the team count?`
        )
      ) {
        return;
      }
      const next = structuredClone(race);
      next.legs.splice(needed);
      while (next.legs.length < needed) {
        next.legs.push(createDefaultLeg({ index: next.legs.length }));
      }
      saveRace(next);
    });
    render();
  }
</script>
