---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Race Builder · Marbel">
  <main class="min-h-full overflow-y-auto bg-canvas text-ink">
    <header
      class="sticky top-0 z-30 border-b border-line bg-canvas/95 px-5 backdrop-blur sm:px-8"
    >
      <div
        class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 py-4"
      >
        <a
          href="/"
          class="text-sm font-semibold text-ink-dim hover:text-ink"
          >← Library</a
        >
        <div class="flex items-center gap-6">
          <span
            id="save-status"
            class="hidden text-xs font-medium text-ink-faint sm:block"
            aria-live="polite">Saved</span
          >
          <a id="play-race" class="pill pill-play text-sm">Play race</a>
        </div>
      </div>
    </header>

    <section
      id="missing-race"
      hidden
      class="mx-auto w-full max-w-7xl px-5 py-28 sm:px-8"
    >
      <h1 class="type-display text-[clamp(2.5rem,7vw,5.5rem)] text-ink-faint">
        Race not found
      </h1>
      <p class="mt-5 text-sm text-ink-dim">
        It may have been deleted from this browser.
      </p>
      <a href="/" class="pill pill-primary mt-8 text-sm">Return to library</a>
    </section>

    <section
      id="race-builder"
      hidden
      class="mx-auto w-full max-w-7xl px-5 pb-24 pt-14 sm:px-8 sm:pt-20"
    >
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_19rem]">
        <div class="min-w-0">
          <label for="race-name" class="sr-only">Race name</label>
          <input
            id="race-name"
            maxlength="80"
            class="type-display w-full border-0 bg-transparent p-0 text-[clamp(2.5rem,5vw,4.5rem)] text-ink caret-brand placeholder:text-ink-faint focus:outline-none"
            placeholder="Untitled race"
          />
        </div>

        <aside class="card self-start p-6">
          <p class="text-xs font-semibold text-ink-faint">Setup</p>
          <div class="mt-5 flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-bold text-ink">Starting teams</p>
              <p class="mt-1 text-xs leading-4 text-ink-dim">
                100 marbles each · one out per leg
              </p>
            </div>
            <div class="flex items-center rounded-full bg-canvas">
              <button
                id="marbles-minus"
                type="button"
                aria-label="Remove a starting team"
                class="size-9 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
                >−</button
              >
              <output
                id="marble-count"
                class="min-w-9 text-center text-sm font-bold tabular-nums text-ink"
                >4</output
              >
              <button
                id="marbles-plus"
                type="button"
                aria-label="Add a starting team"
                class="size-9 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
                >+</button
              >
            </div>
          </div>
          <details class="group mt-6 border-t border-line pt-4">
            <summary
              class="flex cursor-pointer list-none items-center justify-between text-xs font-semibold text-ink-dim hover:text-ink"
            >
              Advanced
              <span
                class="text-ink-faint transition-transform group-open:rotate-90"
                >→</span
              >
            </summary>
            <label class="mt-4 block text-sm font-bold text-ink" for="release-speed"
              >Release interval</label
            >
            <div class="mt-3 flex items-center gap-3">
              <input
                id="release-speed"
                type="range"
                min="20"
                max="240"
                step="20"
                class="w-full accent-brand"
              />
              <output
                id="release-speed-output"
                class="w-16 text-right text-xs tabular-nums text-ink-dim"
              ></output>
            </div>
          </details>
        </aside>
      </div>

      <section id="race-legs" class="mt-20">
        <div
          class="flex flex-col justify-between gap-4 border-t border-line pt-8 sm:flex-row sm:items-end"
        >
          <div>
            <div class="flex items-baseline gap-4">
              <h2 class="type-display text-3xl text-ink sm:text-4xl">
                Race legs
              </h2>
              <span
                id="leg-count"
                class="text-sm font-medium tabular-nums text-ink-faint"
              ></span>
            </div>
            <p
              id="leg-guidance"
              class="mt-3 text-xs font-semibold text-ink-dim"
              aria-live="polite"
            >
            </p>
          </div>
          <div class="flex gap-3">
            <button id="complete-race" type="button" class="pill pill-ghost text-sm"
              >Auto-fill legs</button
            >
            <button id="add-leg" type="button" class="pill pill-primary text-sm"
              >Add leg</button
            >
          </div>
        </div>

        <ol
          id="leg-list"
          class="mt-10 grid gap-x-8 gap-y-14 md:grid-cols-2 xl:grid-cols-3"
        >
        </ol>
      </section>
    </section>
  </main>

  <template id="leg-template">
    <li class="group">
      <div
        class="card relative overflow-hidden group-focus-within:ring-2 group-focus-within:ring-guide"
      >
        <span
          data-leg-number
          class="absolute left-3 top-3 z-10 rounded-full bg-canvas/90 px-2.5 py-1 text-xs font-bold tabular-nums text-ink-dim"
        ></span>
        <canvas data-leg-thumbnail class="block aspect-[16/9] w-full"></canvas>
      </div>
      <label class="mt-4 block">
        <span class="sr-only">Leg name</span>
        <input
          data-leg-name
          maxlength="60"
          class="w-full border-b border-transparent bg-transparent pb-1 text-xl font-extrabold tracking-tight text-ink caret-brand focus:border-brand focus:outline-none"
        />
      </label>
      <div class="mt-3 flex items-center justify-between gap-3">
        <div class="flex items-center">
          <button
            data-move-back
            type="button"
            aria-label="Move leg earlier"
            class="size-8 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
            >←</button
          >
          <button
            data-move-forward
            type="button"
            aria-label="Move leg later"
            class="size-8 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
            >→</button
          >
        </div>
        <div class="flex items-center gap-4">
          <button
            data-duplicate-leg
            type="button"
            class="text-xs font-semibold text-ink-dim hover:text-ink"
            >Duplicate</button
          >
          <button
            data-delete-leg
            type="button"
            class="text-xs font-semibold text-ink-faint hover:text-red-400"
            >Delete</button
          >
          <a data-edit-leg class="pill pill-ghost px-3.5 py-1.5 text-xs"
            >Edit leg</a
          >
        </div>
      </div>
    </li>
  </template>
</Layout>

<script>
  import {
    MAX_RACE_PARTICIPANTS,
    RaceRepository,
    createDefaultLeg,
    createDefaultParticipants,
    createLocalId,
    isRacePlayable,
    renderLevelThumbnail,
    requiredLegCount,
  } from "../races";
  import type { RaceDocument, RaceLegDocument } from "../races";

  const repository = new RaceRepository();
  const params = new URLSearchParams(window.location.search);
  const raceId = params.get("race") ?? "";
  let race: RaceDocument | null = repository.get(raceId);

  const missing = document.querySelector<HTMLElement>("#missing-race");
  const builder = document.querySelector<HTMLElement>("#race-builder");
  const nameInput = document.querySelector<HTMLInputElement>("#race-name");
  const playLink = document.querySelector<HTMLAnchorElement>("#play-race");
  const saveStatus = document.querySelector<HTMLElement>("#save-status");
  const marbleCount =
    document.querySelector<HTMLOutputElement>("#marble-count");
  const marblesMinus =
    document.querySelector<HTMLButtonElement>("#marbles-minus");
  const marblesPlus =
    document.querySelector<HTMLButtonElement>("#marbles-plus");
  const releaseSpeed =
    document.querySelector<HTMLInputElement>("#release-speed");
  const releaseSpeedOutput = document.querySelector<HTMLOutputElement>(
    "#release-speed-output"
  );
  const legCount = document.querySelector<HTMLElement>("#leg-count");
  const legGuidance = document.querySelector<HTMLElement>("#leg-guidance");
  const legList = document.querySelector<HTMLOListElement>("#leg-list");
  const legTemplate =
    document.querySelector<HTMLTemplateElement>("#leg-template");
  const addLegButton = document.querySelector<HTMLButtonElement>("#add-leg");
  const completeRaceButton =
    document.querySelector<HTMLButtonElement>("#complete-race");

  const editLegUrl = (legId: string) =>
    `/level-builder?race=${encodeURIComponent(raceId)}&leg=${encodeURIComponent(legId)}`;

  const showSaved = () => {
    if (!saveStatus) return;
    saveStatus.textContent = "Saved";
  };

  const saveRace = (next: RaceDocument) => {
    race = repository.save(next);
    showSaved();
    render();
  };

  const render = () => {
    if (
      !race ||
      !nameInput ||
      !playLink ||
      !marbleCount ||
      !marblesMinus ||
      !marblesPlus ||
      !releaseSpeed ||
      !releaseSpeedOutput ||
      !legCount ||
      !legGuidance ||
      !legList ||
      !legTemplate ||
      !addLegButton ||
      !completeRaceButton
    ) {
      return;
    }
    if (document.activeElement !== nameInput) nameInput.value = race.name;
    marbleCount.value = `${race.participants.length}`;
    marblesMinus.disabled = race.participants.length <= 2;
    marblesPlus.disabled = race.participants.length >= MAX_RACE_PARTICIPANTS;
    releaseSpeed.value = `${race.releaseIntervalMs}`;
    releaseSpeedOutput.value = `${race.releaseIntervalMs} ms`;

    const needed = requiredLegCount(race);
    const difference = needed - race.legs.length;
    legCount.textContent = `${race.legs.length} / ${needed}`;
    legGuidance.textContent =
      difference === 0
        ? "Ready to play"
        : difference > 0
          ? `Add ${difference} ${difference === 1 ? "leg" : "legs"}`
          : `Remove ${Math.abs(difference)} ${Math.abs(difference) === 1 ? "leg" : "legs"}`;
    legGuidance.className = `mt-3 text-xs font-semibold ${difference === 0 ? "text-ink-dim" : "text-brand"}`;
    addLegButton.disabled = race.legs.length >= MAX_RACE_PARTICIPANTS - 1;
    addLegButton.classList.toggle("opacity-40", addLegButton.disabled);
    completeRaceButton.hidden = difference === 0;

    const playable = isRacePlayable(race);
    playLink.href = playable
      ? `/race?race=${encodeURIComponent(race.id)}`
      : "#race-legs";
    playLink.textContent = playable ? "Play race" : "Finish setup";
    playLink.setAttribute("aria-disabled", `${!playable}`);

    legList.replaceChildren();
    race.legs.forEach((leg, index) => {
      const fragment = legTemplate.content.cloneNode(true) as DocumentFragment;
      const item = fragment.querySelector<HTMLElement>("li");
      const number = fragment.querySelector<HTMLElement>("[data-leg-number]");
      const thumbnail = fragment.querySelector<HTMLCanvasElement>(
        "[data-leg-thumbnail]"
      );
      const legName =
        fragment.querySelector<HTMLInputElement>("[data-leg-name]");
      const moveBack =
        fragment.querySelector<HTMLButtonElement>("[data-move-back]");
      const moveForward = fragment.querySelector<HTMLButtonElement>(
        "[data-move-forward]"
      );
      const duplicate = fragment.querySelector<HTMLButtonElement>(
        "[data-duplicate-leg]"
      );
      const remove =
        fragment.querySelector<HTMLButtonElement>("[data-delete-leg]");
      const edit = fragment.querySelector<HTMLAnchorElement>("[data-edit-leg]");
      if (
        !item ||
        !number ||
        !thumbnail ||
        !legName ||
        !moveBack ||
        !moveForward ||
        !duplicate ||
        !remove ||
        !edit
      )
        return;

      number.textContent = `${index + 1}`.padStart(2, "0");
      legName.value = leg.name;
      moveBack.disabled = index === 0;
      moveForward.disabled = index === race!.legs.length - 1;
      edit.href = editLegUrl(leg.id);
      legName.addEventListener("change", () => {
        if (!race) return;
        const value = legName.value.trim() || `Leg ${index + 1}`;
        const updated: RaceLegDocument = {
          ...leg,
          name: value,
          level: { ...leg.level, name: value },
        };
        race = repository.saveLeg(race.id, updated);
        render();
      });
      moveBack.addEventListener("click", () => {
        if (!race) return;
        race = repository.moveLeg(race.id, leg.id, index - 1);
        render();
      });
      moveForward.addEventListener("click", () => {
        if (!race) return;
        race = repository.moveLeg(race.id, leg.id, index + 1);
        render();
      });
      duplicate.addEventListener("click", () => {
        if (!race || race.legs.length >= MAX_RACE_PARTICIPANTS - 1) return;
        const duplicateName = `${leg.name} copy`;
        const copy: RaceLegDocument = {
          ...structuredClone(leg),
          id: createLocalId(),
          name: duplicateName,
          level: { ...structuredClone(leg.level), name: duplicateName },
        };
        race = repository.addLeg(race.id, copy, index + 1);
        render();
      });
      remove.addEventListener("click", () => {
        if (!race || !window.confirm(`Delete “${leg.name}”?`)) return;
        race = repository.deleteLeg(race.id, leg.id);
        render();
      });

      legList.append(fragment);
      renderLevelThumbnail(thumbnail, leg.level);
    });
  };

  const setParticipantCount = (nextCount: number) => {
    if (!race || nextCount < 2 || nextCount > MAX_RACE_PARTICIPANTS) return;
    const defaults = createDefaultParticipants(nextCount);
    saveRace({
      ...race,
      participants: defaults.map(
        (participant, index) => race!.participants[index] ?? participant
      ),
    });
  };

  if (!race) {
    if (missing) missing.hidden = false;
    if (playLink) playLink.hidden = true;
  } else {
    if (builder) builder.hidden = false;
    nameInput?.addEventListener("change", () => {
      if (!race || !nameInput) return;
      saveRace({ ...race, name: nameInput.value.trim() || "Untitled race" });
    });
    marblesMinus?.addEventListener(
      "click",
      () => race && setParticipantCount(race.participants.length - 1)
    );
    marblesPlus?.addEventListener(
      "click",
      () => race && setParticipantCount(race.participants.length + 1)
    );
    releaseSpeed?.addEventListener("input", () => {
      if (releaseSpeedOutput && releaseSpeed)
        releaseSpeedOutput.value = `${releaseSpeed.value} ms`;
    });
    releaseSpeed?.addEventListener("change", () => {
      if (!race || !releaseSpeed) return;
      saveRace({ ...race, releaseIntervalMs: Number(releaseSpeed.value) });
    });
    addLegButton?.addEventListener("click", () => {
      if (!race || race.legs.length >= MAX_RACE_PARTICIPANTS - 1) return;
      race = repository.addLeg(
        race.id,
        createDefaultLeg({ index: race.legs.length })
      );
      render();
    });
    completeRaceButton?.addEventListener("click", () => {
      if (!race) return;
      const needed = requiredLegCount(race);
      if (
        race.legs.length > needed &&
        !window.confirm(
          `Remove the final ${race.legs.length - needed} ${race.legs.length - needed === 1 ? "leg" : "legs"} to match the team count?`
        )
      ) {
        return;
      }
      const next = structuredClone(race);
      next.legs.splice(needed);
      while (next.legs.length < needed) {
        next.legs.push(createDefaultLeg({ index: next.legs.length }));
      }
      saveRace(next);
    });
    render();
  }
</script>
