---
// Race library homepage — zinc + tangerine brand tokens, uniform 3-column
// grid, width-normalized leg previews behind a bottom fade. Wired to the
// real RaceRepository. Each card links to the race's builder, which acts as
// the pre-launch screen until a dedicated preview page exists.
import Layout from "../layouts/Layout.astro";
import Tooltip from "../ui/Tooltip.astro";
---

<Layout title="Race Library · Marble">
  <main
    class="mx-auto max-w-[68rem] px-6 pb-32 pt-[clamp(2.5rem,7vh,5rem)]"
  >
    <header class="mb-14 flex items-end justify-between gap-8">
      <h1
        class="font-extrabold tracking-[-0.03em] leading-[0.9] text-[clamp(4.5rem,13vw,9rem)] [text-shadow:0.08em_0.09em_0_var(--color-stamp)]"
      >
        Marble Races
      </h1>
    </header>

    <section
      id="grid"
      aria-label="Saved races"
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      <button
        type="button"
        id="create-tile"
        data-create-race
        class="flex h-[26rem] flex-col items-center justify-center gap-5 rounded-[1.25rem] border-2 border-dashed border-line bg-transparent p-6 transition-[border-color] duration-100 ease-out hover:border-ink-dim"
      >
        <span
          class="max-w-56 text-balance text-center text-[1.375rem] font-extrabold leading-[1.2] tracking-[-0.01em] text-ink-dim"
        >
          Let's Get Rolling
        </span>
        <span class="pill pill-primary">
          <!-- lucide: plus -->
          <svg
            class="-ml-1 size-[1.1em]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="M12 5v14"></path>
          </svg>
          New race
        </span>
      </button>
    </section>
  </main>

  <dialog
    id="create-dialog"
    aria-label="New race"
    class="dialog-rise m-auto w-[26rem] max-w-[calc(100vw-2.5rem)] rounded-[1.25rem] bg-panel p-7 text-ink shadow-[0_6px_0_var(--color-shadow)] backdrop:bg-black/60"
  >
    <form id="create-form" novalidate>
      <label for="create-name" class="sr-only">Race name</label>
      <input
        id="create-name"
        type="text"
        maxlength="80"
        autocomplete="off"
        placeholder="Untitled race"
        class="block w-full border-0 bg-transparent p-0 text-[1.75rem] font-extrabold tracking-[-0.02em] leading-tight text-ink caret-brand placeholder:text-ink-faint focus:outline-none"
      />

      <div class="mt-7 flex items-center justify-between gap-4">
        <p class="text-sm font-bold text-ink">Starting teams</p>
        <div class="flex items-center rounded-full bg-canvas">
          <button
            id="create-teams-minus"
            type="button"
            aria-label="Remove a starting team"
            class="size-9 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
            >−</button
          >
          <output
            id="create-team-count"
            class="min-w-9 text-center text-sm font-bold tabular-nums text-ink"
            >4</output
          >
          <button
            id="create-teams-plus"
            type="button"
            aria-label="Add a starting team"
            class="size-9 rounded-full text-ink-dim hover:bg-raise hover:text-ink disabled:text-ink-faint/50 disabled:hover:bg-transparent"
            >+</button
          >
        </div>
      </div>

      <div class="mt-6">
        <label class="block text-sm font-bold text-ink" for="create-marbles"
          >Starting marbles per team</label
        >
        <div class="mt-3 flex items-center gap-3">
          <input
            id="create-marbles"
            type="range"
            min="0"
            max="13"
            step="1"
            class="w-full accent-cyan-400"
          />
          <output
            id="create-marbles-output"
            class="w-16 text-right text-xs tabular-nums text-ink-dim"
          ></output>
        </div>
      </div>

      <p id="create-derived" class="mt-6 text-xs leading-5 text-ink-dim"></p>

      <div class="mt-7 flex items-center justify-center gap-3">
        <button
          id="create-cancel"
          type="button"
          class="pill pill-ghost text-sm hover:transform-none"
          >Cancel</button
        >
        <button type="submit" class="pill pill-primary text-sm"
          >Create race</button
        >
      </div>
    </form>
  </dialog>

  <Tooltip />

  <!-- The whole card is one link to the race's pre-launch screen. The
       hover-revealed actions overlay is a sibling of the link so the
       buttons aren't nested inside it. -->
  <template id="tile">
    <div class="group/tile relative">
      <a
        class="flex h-[26rem] flex-col rounded-[1.25rem] bg-panel p-6 text-inherit no-underline shadow-[0_6px_0_var(--color-shadow)]"
      >
        <h2
          data-name
          class="min-w-0 truncate pr-[4.5rem] text-[1.375rem] font-extrabold leading-[1.15] tracking-[-0.01em]"
        >
        </h2>
        <div
          data-preview
          class="relative mt-[1.125rem] min-h-0 flex-1 overflow-hidden rounded-lg after:pointer-events-none after:absolute after:inset-x-0 after:bottom-0 after:h-14 after:bg-gradient-to-t after:from-panel after:to-transparent"
        >
        </div>
        <div class="mt-5 flex items-center justify-between gap-3">
          <span
            data-legs
            class="whitespace-nowrap text-sm font-medium text-ink-dim"
          ></span>
          <!-- Fixed width so every card's button matches regardless of label.
               Group hover/focus on the wrap presses the candy-pill shadow. -->
          <span
            data-action
            class="pill w-32 px-3 py-2 text-sm group-hover/tile:translate-y-0.5 group-has-[:focus-visible]/tile:translate-y-0.5 group-hover/tile:[&.pill-play]:shadow-[0_2px_0_var(--color-brand-shadow)] group-has-[:focus-visible]/tile:[&.pill-play]:shadow-[0_2px_0_var(--color-brand-shadow)] group-hover/tile:[&.pill-primary]:shadow-[0_2px_0_oklch(58%_0.005_285)] group-has-[:focus-visible]/tile:[&.pill-primary]:shadow-[0_2px_0_oklch(58%_0.005_285)]"
          ></span>
        </div>
      </a>
      <div
        class="absolute top-5 right-6 flex gap-1.5 opacity-0 transition-opacity duration-100 ease-out group-hover/tile:opacity-100 group-focus-within/tile:opacity-100"
      >
        <button
          type="button"
          data-duplicate-race
          aria-label="Duplicate race"
          data-tooltip="Duplicate race"
          class="grid size-8 place-items-center rounded-full bg-canvas/75 text-ink-dim backdrop-blur-[4px] transition-[color,background-color] duration-100 ease-out hover:bg-canvas hover:text-ink"
        >
          <!-- lucide: copy -->
          <svg
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="9" y="9" width="12" height="12" rx="2.5"></rect>
            <path
              d="M5 15H4.5A1.5 1.5 0 0 1 3 13.5v-9A1.5 1.5 0 0 1 4.5 3h9A1.5 1.5 0 0 1 15 4.5V5"
            ></path>
          </svg>
        </button>
        <button
          type="button"
          data-delete-race
          aria-label="Delete race"
          data-tooltip="Delete race"
          class="grid size-8 place-items-center rounded-full bg-canvas/75 text-ink-dim backdrop-blur-[4px] transition-[color,background-color] duration-100 ease-out hover:bg-canvas hover:text-[oklch(70%_0.19_25)]"
        >
          <!-- lucide: trash -->
          <svg
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 6h18"></path>
            <path
              d="M19 6v13.5A1.5 1.5 0 0 1 17.5 21h-11A1.5 1.5 0 0 1 5 19.5V6"
            ></path>
            <path d="M8 6V4.5A1.5 1.5 0 0 1 9.5 3h5A1.5 1.5 0 0 1 16 4.5V6"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </template>

  <script>
    import { mountRaceLibrary } from "../scenes/race-library/mount";
    mountRaceLibrary();
  </script>
</Layout>
