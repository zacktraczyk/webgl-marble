---
// Race library homepage — zinc + tangerine brand tokens, uniform 3-column
// grid, width-normalized leg previews behind a bottom fade. Wired to the
// real RaceRepository. Each card links to the race's builder, which acts as
// the pre-launch screen until a dedicated preview page exists.
import Layout from "../layouts/Layout.astro";
import Tooltip from "../ui/Tooltip.astro";
---

<Layout title="Race Library · Marbel">
  <main
    class="mx-auto max-w-[68rem] px-6 pb-32 pt-[clamp(2.5rem,7vh,5rem)]"
  >
    <header class="mb-14 flex items-end justify-between gap-8">
      <h1
        class="font-extrabold tracking-[-0.03em] leading-[0.9] text-[clamp(4.5rem,13vw,9rem)] [text-shadow:0.08em_0.09em_0_var(--color-stamp)]"
      >
        Marble Races
      </h1>
    </header>

    <section
      id="grid"
      aria-label="Saved races"
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      <button
        type="button"
        id="create-tile"
        data-create-race
        class="flex h-[26rem] flex-col items-center justify-center gap-5 rounded-[1.25rem] border-2 border-dashed border-line bg-transparent p-6 transition-[border-color] duration-100 ease-out hover:border-ink-dim"
      >
        <span
          class="max-w-56 text-balance text-center text-[1.375rem] font-extrabold leading-[1.2] tracking-[-0.01em] text-ink-dim"
        >
          Let's Get Rolling
        </span>
        <span class="pill pill-primary">
          <!-- lucide: plus -->
          <svg
            class="-ml-1 size-[1.1em]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="M12 5v14"></path>
          </svg>
          New race
        </span>
      </button>
    </section>
  </main>

  <Tooltip />

  <!-- The whole card is one link to the race's pre-launch screen. The
       hover-revealed actions overlay is a sibling of the link so the
       buttons aren't nested inside it. -->
  <template id="tile">
    <div class="group/tile relative">
      <a
        class="flex h-[26rem] flex-col rounded-[1.25rem] bg-panel p-6 text-inherit no-underline shadow-[0_6px_0_var(--color-shadow)]"
      >
        <h2
          data-name
          class="min-w-0 truncate pr-[4.5rem] text-[1.375rem] font-extrabold leading-[1.15] tracking-[-0.01em]"
        >
        </h2>
        <div
          data-preview
          class="relative mt-[1.125rem] min-h-0 flex-1 overflow-hidden rounded-lg after:pointer-events-none after:absolute after:inset-x-0 after:bottom-0 after:h-14 after:bg-gradient-to-t after:from-panel after:to-transparent"
        >
        </div>
        <div class="mt-5 flex items-center justify-between gap-3">
          <span
            data-legs
            class="whitespace-nowrap text-sm font-medium text-ink-dim"
          ></span>
          <!-- Fixed width so every card's button matches regardless of label.
               Group hover/focus on the wrap presses the candy-pill shadow. -->
          <span
            data-action
            class="pill w-32 px-3 py-2 text-sm group-hover/tile:translate-y-0.5 group-has-[:focus-visible]/tile:translate-y-0.5 group-hover/tile:[&.pill-play]:shadow-[0_2px_0_var(--color-brand-shadow)] group-has-[:focus-visible]/tile:[&.pill-play]:shadow-[0_2px_0_var(--color-brand-shadow)] group-hover/tile:[&.pill-primary]:shadow-[0_2px_0_oklch(58%_0.005_285)] group-has-[:focus-visible]/tile:[&.pill-primary]:shadow-[0_2px_0_oklch(58%_0.005_285)]"
          ></span>
        </div>
      </a>
      <div
        class="absolute top-5 right-6 flex gap-1.5 opacity-0 transition-opacity duration-100 ease-out group-hover/tile:opacity-100 group-focus-within/tile:opacity-100"
      >
        <button
          type="button"
          data-duplicate-race
          aria-label="Duplicate race"
          data-tooltip="Duplicate race"
          class="grid size-8 place-items-center rounded-full bg-canvas/75 text-ink-dim backdrop-blur-[4px] transition-[color,background-color] duration-100 ease-out hover:bg-canvas hover:text-ink"
        >
          <!-- lucide: copy -->
          <svg
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="9" y="9" width="12" height="12" rx="2.5"></rect>
            <path
              d="M5 15H4.5A1.5 1.5 0 0 1 3 13.5v-9A1.5 1.5 0 0 1 4.5 3h9A1.5 1.5 0 0 1 15 4.5V5"
            ></path>
          </svg>
        </button>
        <button
          type="button"
          data-delete-race
          aria-label="Delete race"
          data-tooltip="Delete race"
          class="grid size-8 place-items-center rounded-full bg-canvas/75 text-ink-dim backdrop-blur-[4px] transition-[color,background-color] duration-100 ease-out hover:bg-canvas hover:text-[oklch(70%_0.19_25)]"
        >
          <!-- lucide: trash -->
          <svg
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 6h18"></path>
            <path
              d="M19 6v13.5A1.5 1.5 0 0 1 17.5 21h-11A1.5 1.5 0 0 1 5 19.5V6"
            ></path>
            <path d="M8 6V4.5A1.5 1.5 0 0 1 9.5 3h5A1.5 1.5 0 0 1 16 4.5V6"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </template>

  <script>
    import {
      RaceRepository,
      createDefaultRace,
      isRacePlayable,
      renderLevelThumbnail,
      requiredLegCount,
    } from "../races";
    import { attachTooltip } from "../ui/tooltip";

    attachTooltip(document.body);
    const repository = new RaceRepository();
    const grid = document.querySelector<HTMLElement>("#grid");
    const template = document.querySelector<HTMLTemplateElement>("#tile");
    const createTile = document.querySelector<HTMLElement>("#create-tile");

    const builderUrl = (raceId: string) =>
      `/race-builder?race=${encodeURIComponent(raceId)}`;

    const createRace = () => {
      const race = repository.create(createDefaultRace());
      window.location.assign(builderUrl(race.id));
    };

    const renderLibrary = () => {
      if (!grid || !template || !createTile) return;
      const races = repository.list();
      grid.replaceChildren();

      const pending: (() => void)[] = [];
      for (const race of races) {
        const fragment = template.content.cloneNode(true) as DocumentFragment;
        const playable = isRacePlayable(race);
        fragment.querySelector<HTMLAnchorElement>("a")!.href = builderUrl(
          race.id
        );
        fragment.querySelector("[data-name]")!.textContent = race.name;
        fragment.querySelector("[data-legs]")!.textContent =
          `${race.legs.length} ${race.legs.length === 1 ? "leg" : "legs"}`;

        const preview = fragment.querySelector<HTMLElement>("[data-preview]")!;
        const strip = document.createElement("div");
        strip.className = "flex flex-col gap-1.5";
        preview.append(strip);
        const canvases = race.legs.map((leg) => {
          const canvas = document.createElement("canvas");
          canvas.className = "block w-full rounded-lg";
          canvas.style.aspectRatio = `${leg.level.size[0]} / ${leg.level.size[1]}`;
          strip.append(canvas);
          return canvas;
        });
        // Draw after the cards are in the document so sizes are measurable.
        pending.push(() => {
          race.legs.forEach((leg, index) => {
            renderLevelThumbnail(canvases[index], leg.level, {
              background: "oklch(19% 0.004 285)",
              courseBackground: "oklch(26% 0.005 285)",
              border: "oklch(38% 0.006 285)",
              teamCount: race.participants.length - index,
            });
          });
        });

        fragment
          .querySelector<HTMLButtonElement>("[data-duplicate-race]")!
          .addEventListener("click", () => {
            repository.duplicateRace(race.id);
            renderLibrary();
          });
        fragment
          .querySelector<HTMLButtonElement>("[data-delete-race]")!
          .addEventListener("click", () => {
            if (!confirm(`Delete "${race.name}"? This can't be undone.`))
              return;
            repository.delete(race.id);
            renderLibrary();
          });

        const action = fragment.querySelector<HTMLElement>("[data-action]")!;
        action.textContent = playable ? "Preview" : "Finish setup";
        action.classList.add(playable ? "pill-play" : "pill-primary");
        if (!playable) {
          const difference = requiredLegCount(race) - race.legs.length;
          action.dataset.tooltip =
            difference > 0
              ? `Add ${difference} ${difference === 1 ? "leg" : "legs"} to play`
              : `Remove ${Math.abs(difference)} ${Math.abs(difference) === 1 ? "leg" : "legs"} to play`;
        }
        grid.append(fragment);
      }
      grid.append(createTile);
      for (const draw of pending) draw();
    };

    for (const button of document.querySelectorAll<HTMLButtonElement>(
      "[data-create-race]"
    )) {
      button.addEventListener("click", createRace);
    }
    renderLibrary();
  </script>
</Layout>
