---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Race Library · Marbel">
  <main class="min-h-full overflow-y-auto bg-zinc-900 text-zinc-100">
    <header class="border-b border-zinc-800 bg-zinc-900/95 px-5 py-4 sm:px-8">
      <div
        class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4"
      >
        <a
          href="/"
          class="flex items-center gap-3 font-semibold tracking-tight text-white"
        >
          <span
            class="grid size-8 place-items-center rounded-full border border-zinc-600 bg-zinc-100 text-xs font-black text-zinc-900"
            >M</span
          >
          Marbel
        </a>
        <nav class="flex items-center gap-2" aria-label="Primary navigation">
          <a
            href="/dev/"
            class="rounded-md px-3 py-2 text-sm text-zinc-400 hover:bg-zinc-800 hover:text-white"
            >Developer Lab</a
          >
          <button
            data-create-race
            type="button"
            class="rounded-md bg-zinc-100 px-4 py-2 text-sm font-semibold text-zinc-900 hover:bg-white"
          >
            New race
          </button>
        </nav>
      </div>
    </header>

    <section class="mx-auto w-full max-w-7xl px-5 py-10 sm:px-8 sm:py-14">
      <div class="flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
        <div>
          <p
            class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500"
          >
            Saved on this device
          </p>
          <h1
            class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl"
          >
            Race library
          </h1>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
            Build a sequence of legs. Every team starts each leg with 100
            marbles; the team with the final marble left on the track is
            eliminated.
          </p>
        </div>
        <p id="library-count" class="text-sm text-zinc-500" aria-live="polite">
        </p>
      </div>

      <section
        id="library-empty"
        hidden
        class="mt-10 rounded-2xl border border-dashed border-zinc-700 bg-zinc-800/30 px-6 py-16 text-center"
      >
        <div
          class="mx-auto grid size-14 place-items-center rounded-full border border-zinc-700 bg-zinc-800 text-2xl text-zinc-300"
          aria-hidden="true"
        >
          ●
        </div>
        <h2 class="mt-5 text-lg font-semibold text-white">
          Make your first race
        </h2>
        <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-zinc-400">
          Start with one editable leg. Add and arrange more legs in the race
          builder when you are ready.
        </p>
        <button
          data-create-race
          type="button"
          class="mt-6 rounded-md bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-900 hover:bg-white"
        >
          Create a race
        </button>
      </section>

      <section
        id="race-grid"
        aria-label="Saved races"
        class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3"
      >
      </section>
    </section>
  </main>

  <template id="race-card-template">
    <article
      class="group overflow-hidden rounded-2xl border border-zinc-700 bg-zinc-800/70 shadow-sm transition hover:border-zinc-600 hover:bg-zinc-800"
    >
      <a
        data-race-preview
        class="relative block aspect-[16/9] overflow-hidden border-b border-zinc-700 bg-zinc-950"
      >
        <canvas data-race-thumbnail class="size-full"></canvas>
        <span
          data-race-status
          class="absolute left-3 top-3 rounded-full border border-zinc-600 bg-zinc-900/85 px-2.5 py-1 text-[11px] font-medium text-zinc-200 backdrop-blur"
        ></span>
        <span
          class="absolute bottom-3 right-3 rounded-md bg-zinc-100 px-3 py-1.5 text-xs font-semibold text-zinc-900 opacity-0 transition group-hover:opacity-100"
          >Open builder</span
        >
      </a>
      <div class="p-5">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <h2
              data-race-name
              class="truncate text-lg font-semibold text-white"
            >
            </h2>
            <p data-race-meta class="mt-1 text-xs text-zinc-500"></p>
          </div>
          <button
            data-race-delete
            type="button"
            class="shrink-0 rounded-md px-2 py-1 text-xs text-zinc-500 hover:bg-zinc-700 hover:text-rose-300"
            >Delete</button
          >
        </div>
        <div class="mt-5 flex gap-2">
          <a
            data-race-edit
            class="flex-1 rounded-md border border-zinc-600 px-3 py-2 text-center text-sm font-medium text-zinc-200 hover:bg-zinc-700 hover:text-white"
            >Edit</a
          >
          <a
            data-race-play
            class="flex-1 rounded-md bg-zinc-100 px-3 py-2 text-center text-sm font-semibold text-zinc-900 hover:bg-white"
            >Play</a
          >
        </div>
      </div>
    </article>
  </template>
</Layout>

<script>
  import {
    RaceRepository,
    createDefaultRace,
    isRacePlayable,
    renderLevelThumbnail,
    requiredLegCount,
  } from "../races";

  const repository = new RaceRepository();
  const grid = document.querySelector<HTMLElement>("#race-grid");
  const emptyState = document.querySelector<HTMLElement>("#library-empty");
  const countOutput = document.querySelector<HTMLElement>("#library-count");
  const template = document.querySelector<HTMLTemplateElement>(
    "#race-card-template"
  );

  const raceUrl = (path: "builder" | "play", raceId: string) =>
    `/${path === "builder" ? "race-builder" : "race"}?race=${encodeURIComponent(raceId)}`;

  const createRace = () => {
    const race = repository.create(createDefaultRace());
    window.location.assign(raceUrl("builder", race.id));
  };

  const renderLibrary = () => {
    if (!grid || !emptyState || !countOutput || !template) {
      return;
    }
    const races = repository.list();
    grid.replaceChildren();
    emptyState.hidden = races.length > 0;
    countOutput.textContent = `${races.length} ${races.length === 1 ? "race" : "races"}`;

    for (const race of races) {
      const fragment = template.content.cloneNode(true) as DocumentFragment;
      const article = fragment.querySelector<HTMLElement>("article");
      const preview = fragment.querySelector<HTMLAnchorElement>(
        "[data-race-preview]"
      );
      const thumbnail = fragment.querySelector<HTMLCanvasElement>(
        "[data-race-thumbnail]"
      );
      const name = fragment.querySelector<HTMLElement>("[data-race-name]");
      const meta = fragment.querySelector<HTMLElement>("[data-race-meta]");
      const status = fragment.querySelector<HTMLElement>("[data-race-status]");
      const edit =
        fragment.querySelector<HTMLAnchorElement>("[data-race-edit]");
      const play =
        fragment.querySelector<HTMLAnchorElement>("[data-race-play]");
      const remove =
        fragment.querySelector<HTMLButtonElement>("[data-race-delete]");
      if (
        !article ||
        !preview ||
        !thumbnail ||
        !name ||
        !meta ||
        !status ||
        !edit ||
        !play ||
        !remove
      ) {
        continue;
      }

      const editHref = raceUrl("builder", race.id);
      preview.href = editHref;
      edit.href = editHref;
      name.textContent = race.name;
      const updated = new Intl.DateTimeFormat(undefined, {
        month: "short",
        day: "numeric",
      }).format(new Date(race.updatedAt));
      meta.textContent = `${race.participants.length} teams · ${race.rules.marblesPerTeam} marbles each · ${race.legs.length} ${race.legs.length === 1 ? "leg" : "legs"} · Edited ${updated}`;

      const playable = isRacePlayable(race);
      status.textContent = playable
        ? "Ready to race"
        : `${requiredLegCount(race) - race.legs.length > 0 ? requiredLegCount(race) - race.legs.length : race.legs.length - requiredLegCount(race)} ${race.legs.length < requiredLegCount(race) ? "more" : "fewer"} ${Math.abs(requiredLegCount(race) - race.legs.length) === 1 ? "leg" : "legs"} needed`;
      play.href = playable ? raceUrl("play", race.id) : editHref;
      play.textContent = playable ? "Play" : "Finish setup";

      remove.addEventListener("click", () => {
        if (window.confirm(`Delete “${race.name}”? This cannot be undone.`)) {
          repository.delete(race.id);
          renderLibrary();
        }
      });

      grid.append(fragment);
      if (race.legs[0]) {
        renderLevelThumbnail(thumbnail, race.legs[0].level);
      }
    }
  };

  for (const button of document.querySelectorAll<HTMLButtonElement>(
    "[data-create-race]"
  )) {
    button.addEventListener("click", createRace);
  }
  renderLibrary();
</script>
