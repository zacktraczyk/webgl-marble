---
import HomeLink from "../../components/HomeLink.astro";
import Layout from "../../layouts/Layout.astro";

const pages = [
  {
    name: "Level Builder",
    href: "/level-builder",
    note: "Current leg authoring prototype",
  },
  { name: "First Race", href: "/first-race", note: "Original race simulation" },
  { name: "Second Race", href: "/second-race", note: "Alternate race setup" },
  { name: "Random Balls", href: "/random-balls", note: "Physics load test" },
  { name: "Arrow", href: "/arrow", note: "Primitive rendering" },
  {
    name: "Angular Collisions",
    href: "/angular-collisions",
    note: "Rotation and collision test",
  },
  {
    name: "SAT Collision",
    href: "/sat-collision",
    note: "SAT narrowphase test",
  },
  {
    name: "GJK Collision",
    href: "/gjk-collision",
    note: "GJK narrowphase test",
  },
  {
    name: "Collision Resolution",
    href: "/collision-resolution",
    note: "Impulse resolution test",
  },
  {
    name: "Kinematic Forces",
    href: "/kinematic-forces",
    note: "Kinematic motion test",
  },
];
---

<Layout title="Developer Lab · Marbel">
  <main class="min-h-full overflow-y-auto bg-zinc-900 px-5 py-20 sm:px-8">
    <HomeLink label="Race library" />
    <section class="mx-auto w-full max-w-5xl">
      <p
        class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500"
      >
        Local development
      </p>
      <h1
        class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl"
      >
        Developer Lab
      </h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
        The original debug and engine prototype screens live here. These routes
        stay separate from the race-making workflow.
      </p>

      <div class="mt-10 grid gap-3 sm:grid-cols-2">
        {
          pages.map((page) => (
            <a
              href={page.href}
              class="group rounded-xl border border-zinc-700 bg-zinc-800/70 p-5 transition hover:border-zinc-500 hover:bg-zinc-800"
            >
              <div class="flex items-center justify-between gap-4">
                <h2 class="font-medium text-zinc-100 group-hover:text-white">
                  {page.name}
                </h2>
                <span
                  aria-hidden="true"
                  class="text-zinc-600 transition group-hover:translate-x-0.5 group-hover:text-zinc-300"
                >
                  →
                </span>
              </div>
              <p class="mt-2 text-sm text-zinc-500">{page.note}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
