---
import HomeLink from "../../ui/HomeLink.astro";
import Layout from "../../layouts/Layout.astro";
import Tooltip from "../../ui/Tooltip.astro";
import Toolbar from "./_Toolbar.astro";
import ViewportChrome from "./_ViewportChrome.astro";
import RaceControls from "./_RaceControls.astro";
import OptionsSidebar from "./_OptionsSidebar.astro";
import ContextMenu from "./_ContextMenu.astro";
import "./_leg-builder.css";
---

<Layout>
  <main
    id="leg-builder"
    data-sidebar-open="false"
    data-sidebar-ready="false"
    data-previewing="false"
    class="relative size-full overflow-hidden"
  >
    <HomeLink id="builder-home-link" />
    <p
      id="builder-error"
      class="pointer-events-none absolute left-1/2 top-24 z-30 -translate-x-1/2 rounded-md border border-rose-900 bg-rose-950/90 px-3 py-2 font-mono text-xs text-rose-200 shadow-lg backdrop-blur empty:hidden"
    >
    </p>

    <Toolbar />

    <p
      id="tool-hint"
      data-role="tool-hint"
      aria-live="polite"
      class="pointer-events-none absolute inset-x-0 top-16 z-20 mx-auto w-max whitespace-nowrap text-center text-xs text-zinc-500"
    >
      Hold <kbd>Space</kbd> and drag to pan
    </p>

    <ViewportChrome />

    <RaceControls />

    <Tooltip id="builder-tooltip" />

    <div
      id="leg-options-card"
      data-role="options-card"
      class="absolute right-3 top-3 z-30 flex flex-col overflow-hidden rounded-lg border border-zinc-700 bg-zinc-800/90 shadow-lg backdrop-blur"
    >
      <button
        id="toggle-sidebar"
        type="button"
        aria-controls="leg-options-sidebar"
        aria-expanded="false"
        aria-label="Open options sidebar"
        data-tooltip="Open Sidebar"
        data-tooltip-dismiss-on-click
        class="flex h-9 w-full shrink-0 items-center justify-between gap-2 rounded-md bg-transparent px-3 text-sm text-zinc-200 hover:bg-zinc-700 hover:text-white"
      >
        <span>Options</span>
        <span class="relative size-5 shrink-0" aria-hidden="true">
          <svg
            data-sidebar-icon="open"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="absolute inset-0 size-5"
          >
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <path d="M15 3v18"></path>
          </svg>
          <svg
            data-sidebar-icon="close"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="absolute inset-0 size-5"
          >
            <path d="m18 6-12 12M6 6l12 12"></path>
          </svg>
        </span>
      </button>

      <OptionsSidebar />
    </div>

    <ContextMenu />

    <div id="builder-workspace" class="absolute inset-0 overflow-hidden">
      <canvas
        id="gl-canvas"
        tabindex="-1"
        class="size-full bg-zinc-900 data-[pointer=pan]:cursor-grab data-[pointer=select]:cursor-default data-[pointer=shape]:cursor-crosshair"
      >
        Canvas not supported
      </canvas>
      <div id="builder-grid" data-role="grid-overlay" aria-hidden="true"></div>
      <canvas
        id="editor-overlay"
        data-role="editor-overlay"
        class="pointer-events-none absolute inset-0 z-10 size-full"
        aria-hidden="true"></canvas>
    </div>
  </main>
</Layout>

<script>
  import { reportOperationFailure } from "../../lib/analytics";
  import { mountScene } from "../../scenes/mount";
  import { setInlineError } from "../../ui/pageError";
  import createScene from "../../scenes/leg-builder";

  const errorElement = document.getElementById("builder-error");
  try {
    mountScene(createScene(), {
      errorElement,
      onError: (error, phase) => {
        const reason =
          phase === "load" ? "initialization_error" : "runtime_error";
        reportOperationFailure({
          surface: "leg_builder",
          operation: "load_leg_builder",
          reason,
          error,
        });
      },
    });
  } catch (error) {
    reportOperationFailure({
      surface: "leg_builder",
      operation: "load_leg_builder",
      reason: "initialization_error",
      error,
    });
    setInlineError(errorElement, error);
  }
</script>
