<nav
  id="builder-race-controls"
  data-role="race-controls"
  aria-label="Race controls"
  class="absolute bottom-3 left-1/2 z-30 flex -translate-x-1/2 items-center gap-1.5 rounded-xl border border-zinc-700 bg-zinc-800/90 p-1.5 shadow-lg backdrop-blur"
>
  <button
    id="run-race"
    data-role="race-play"
    type="button"
    aria-label="Run race"
    data-tooltip="Run race"
    data-previewing="false"
    class="flex size-10 items-center justify-center rounded-lg bg-brand text-brand-ink hover:bg-brand-hot disabled:cursor-not-allowed disabled:bg-zinc-600 disabled:text-zinc-400 disabled:hover:bg-zinc-600"
  >
    <svg
      data-race-icon="play"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="size-5"
      aria-hidden="true"
    >
      <path d="M8 5v14l11-7z"></path>
    </svg>
    <svg
      data-race-icon="pause"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="hidden size-5"
      aria-hidden="true"
    >
      <path d="M6 5h4v14H6zM14 5h4v14h-4z"></path>
    </svg>
    <svg
      data-race-icon="replay"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="hidden size-5"
      aria-hidden="true"
    >
      <path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path>
      <path d="M3 3v5h5"></path>
    </svg>
    <span data-race-button-label class="sr-only">Run race</span>
  </button>
  <button
    id="reset-race"
    data-role="race-reset"
    type="button"
    aria-label="End preview and return to editor"
    data-tooltip="End preview"
    disabled
    class="flex size-10 items-center justify-center rounded-lg text-zinc-100 hover:bg-zinc-700 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:hover:bg-transparent"
  >
    <svg
      viewBox="0 0 24 24"
      fill="currentColor"
      class="size-5"
      aria-hidden="true"
    >
      <rect x="6" y="6" width="12" height="12" rx="1"></rect>
    </svg>
  </button>
</nav>

<div
  id="race-outcome"
  data-role="race-outcome"
  role="status"
  aria-live="polite"
  aria-atomic="true"
  hidden
  class="pointer-events-none absolute inset-x-0 bottom-20 z-20 mx-auto flex w-max items-center gap-2.5 rounded-xl border border-zinc-600 bg-zinc-800/95 px-3.5 py-2.5 shadow-xl backdrop-blur"
>
  <span
    data-race-outcome-swatch
    aria-hidden="true"
    class="size-5 shrink-0 rounded-full ring-2 ring-white/25"></span>
  <strong
    data-race-outcome-label
    class="whitespace-nowrap text-sm font-semibold text-zinc-50"
    >Round complete</strong
  >
</div>
