---
import {
  COURSE_STROKE_WIDTH,
  MAX_STAGE_HEIGHT,
  MAX_STAGE_WIDTH,
  MAX_WALL_THICKNESS,
  MIN_STAGE_HEIGHT,
  MIN_STAGE_WIDTH,
  MIN_WALL_THICKNESS,
  STAGE_HEIGHT,
  STAGE_SIZE_STEP,
  STAGE_WIDTH,
} from "../../game/level/constants";
import ObjectInspector from "./_ObjectInspector.astro";
---

<aside
  id="leg-options-sidebar"
  aria-label="Editor options"
  aria-hidden="true"
  inert
  class="absolute inset-y-0 right-0 z-20 flex w-64 flex-col overflow-y-auto border-l border-zinc-700 bg-zinc-800 p-4 transition-transform duration-200"
>
  <ObjectInspector />

  <div data-role="scene-options" class="mt-9 divide-y divide-zinc-700">
    <div class="py-4">
      <p class="mb-3 text-xs font-medium text-zinc-300">Course size</p>
      <div class="grid grid-cols-2 gap-2">
        <label class="relative" for="course-width">
          <span class="sr-only">Course width</span>
          <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-y-0 left-2 flex items-center font-mono text-[11px] text-zinc-500"
            >W</span
          >
          <input
            id="course-width"
            data-role="course-width"
            type="number"
            min={MIN_STAGE_WIDTH}
            max={MAX_STAGE_WIDTH}
            step={STAGE_SIZE_STEP}
            value={STAGE_WIDTH}
            class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-6 pr-2 font-mono text-xs text-zinc-200 outline-none focus:border-cyan-500"
          />
        </label>
        <label class="relative" for="course-height">
          <span class="sr-only">Course height</span>
          <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-y-0 left-2 flex items-center font-mono text-[11px] text-zinc-500"
            >H</span
          >
          <input
            id="course-height"
            data-role="course-height"
            type="number"
            min={MIN_STAGE_HEIGHT}
            max={MAX_STAGE_HEIGHT}
            step={STAGE_SIZE_STEP}
            value={STAGE_HEIGHT}
            class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-6 pr-2 font-mono text-xs text-zinc-200 outline-none focus:border-cyan-500"
          />
        </label>
      </div>
    </div>

    <label
      class="flex items-center gap-3 py-3 text-zinc-300"
      for="wall-thickness"
      data-tooltip="Default wall thickness"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        class="size-5 shrink-0"
        aria-hidden="true"
      >
        <path d="M4 8h16M4 16h16"></path>
        <path d="M7 5v6M17 13v6"></path>
      </svg>
      <span class="text-sm">Wall thickness</span>
      <input
        id="wall-thickness"
        data-role="wall-thickness"
        type="number"
        min={MIN_WALL_THICKNESS}
        max={MAX_WALL_THICKNESS}
        step="1"
        value={COURSE_STROKE_WIDTH}
        class="ml-auto w-16 rounded-md border border-zinc-600 bg-zinc-900 px-2 py-1.5 text-right font-mono text-xs text-zinc-200 outline-none focus:border-cyan-500"
      />
    </label>

    <section aria-labelledby="spawn-settings-heading" class="py-3">
      <h2
        id="spawn-settings-heading"
        class="mb-1 text-xs font-medium text-zinc-400"
      >
        Spawn settings
      </h2>

      <div
        role="tablist"
        aria-label="Spawn type"
        class="mb-1 mt-2 grid grid-cols-2 overflow-hidden rounded-md border border-zinc-600"
      >
        <button
          id="spawn-type-point"
          data-role="spawn-type-point"
          type="button"
          role="tab"
          aria-selected="true"
          data-active="true"
          class="px-2 py-1.5 text-xs text-zinc-300 hover:bg-zinc-700 data-[active=true]:bg-cyan-400 data-[active=true]:font-medium data-[active=true]:text-cyan-950 disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:bg-transparent"
          >Point</button
        >
        <button
          id="spawn-type-top-slider"
          data-role="spawn-type-top-slider"
          type="button"
          role="tab"
          aria-selected="false"
          data-active="false"
          class="border-l border-zinc-600 px-2 py-1.5 text-xs text-zinc-300 hover:bg-zinc-700 data-[active=true]:bg-cyan-400 data-[active=true]:font-medium data-[active=true]:text-cyan-950 disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:bg-transparent"
          >Top slider</button
        >
      </div>
      <p class="mb-1 text-[10px] leading-4 text-zinc-500">
        Top slider sweeps along the top edge and drops marbles as it moves.
      </p>

      <label
        class="flex items-center gap-3 py-2.5 text-zinc-300"
        for="team-count"
        data-tooltip="Teams"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5 shrink-0"
          aria-hidden="true"
        >
          <circle cx="8" cy="8" r="3"></circle>
          <circle cx="17" cy="9" r="2"></circle>
          <path d="M3 20v-2a5 5 0 0 1 10 0v2M14 15a4 4 0 0 1 7 3v2"></path>
        </svg>
        <span class="sr-only">Teams</span>
        <input
          id="team-count"
          data-role="team-count"
          class="min-w-0 flex-1 accent-zinc-100"
          type="range"
          min="2"
          max="12"
          value="12"
        />
        <output
          id="team-count-output"
          data-role="team-count-output"
          class="w-7 text-right font-mono text-xs text-zinc-400"
          for="team-count">12</output
        >
      </label>

      <label
        class="flex items-center gap-3 py-2.5 text-zinc-300"
        for="marbles-per-team"
        data-tooltip="Marbles per team"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="size-5 shrink-0"
          aria-hidden="true"
        >
          <circle cx="8" cy="8" r="3"></circle>
          <circle cx="16" cy="8" r="3"></circle>
          <circle cx="12" cy="16" r="3"></circle>
        </svg>
        <span class="sr-only">Marbles per team</span>
        <input
          id="marbles-per-team"
          data-role="marbles-per-team"
          class="min-w-0 flex-1 accent-zinc-100"
          type="range"
          min="1"
          max="100"
          value="100"
        />
        <output
          id="marbles-per-team-output"
          data-role="marbles-per-team-output"
          class="w-7 text-right font-mono text-xs text-zinc-400"
          for="marbles-per-team">100</output
        >
      </label>

      <label
        class="flex items-center gap-3 py-2.5 text-zinc-300"
        for="release-interval"
        data-tooltip="Release interval"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5 shrink-0"
          aria-hidden="true"
        >
          <circle cx="12" cy="13" r="8"></circle>
          <path d="M12 9v4l3 2M9 2h6"></path>
        </svg>
        <span class="sr-only">Release interval</span>
        <input
          id="release-interval"
          data-role="release-interval"
          class="min-w-0 flex-1 accent-zinc-100"
          type="range"
          min="10"
          max="250"
          step="10"
          value="20"
        />
        <output
          id="release-interval-output"
          data-role="release-interval-output"
          class="w-14 text-right font-mono text-xs text-zinc-400"
          for="release-interval">20 ms</output
        >
      </label>
    </section>

    <section
      aria-labelledby="grid-options-heading"
      class="border-b border-zinc-700 py-3"
    >
      <h2
        id="grid-options-heading"
        class="mb-1 text-xs font-medium text-zinc-400"
      >
        Grid
      </h2>

      <button
        id="toggle-grid-snap"
        data-role="grid-snap-toggle"
        type="button"
        role="switch"
        aria-checked="true"
        data-active="true"
        class="group flex w-full items-center gap-3 py-2.5 text-left text-zinc-300 hover:text-zinc-100"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5 shrink-0"
          aria-hidden="true"
        >
          <path d="M8 4H4v4M16 4h4v4M8 20H4v-4M16 20h4v-4"></path>
          <path d="M12 8v8M8 12h8"></path>
        </svg>
        <span class="text-sm">Snap to grid</span>
        <span
          aria-hidden="true"
          class="relative ml-auto h-5 w-9 rounded-full bg-zinc-600 transition-colors group-data-[active=true]:bg-cyan-400"
        >
          <span
            class="absolute left-0.5 top-0.5 size-4 rounded-full bg-white shadow-sm transition-transform group-data-[active=true]:translate-x-4"
          ></span>
        </span>
      </button>

      <button
        id="toggle-major-grid"
        data-role="major-grid-toggle"
        type="button"
        role="switch"
        aria-checked="true"
        data-active="true"
        class="group flex w-full items-center gap-3 py-2.5 text-left text-zinc-300 hover:text-zinc-100"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="size-5 shrink-0"
          aria-hidden="true"
        >
          <circle cx="5" cy="5" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="12" cy="5" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="19" cy="5" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="5" cy="12" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="19" cy="12" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="12" cy="19" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="19" cy="19" r="1" fill="currentColor" stroke="none"
          ></circle>
        </svg>
        <span class="text-sm">Major dots</span>
        <span
          aria-hidden="true"
          class="relative ml-auto h-5 w-9 rounded-full bg-zinc-600 transition-colors group-data-[active=true]:bg-cyan-400"
        >
          <span
            class="absolute left-0.5 top-0.5 size-4 rounded-full bg-white shadow-sm transition-transform group-data-[active=true]:translate-x-4"
          ></span>
        </span>
      </button>

      <button
        id="toggle-minor-grid"
        data-role="minor-grid-toggle"
        type="button"
        role="switch"
        aria-checked="false"
        data-active="false"
        class="group flex w-full items-center gap-3 py-2.5 text-left text-zinc-300 hover:text-zinc-100"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="size-5 shrink-0"
          aria-hidden="true"
        >
          <circle cx="5" cy="5" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="12" cy="5" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="19" cy="5" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="5" cy="12" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="19" cy="12" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="12" cy="19" r="1" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="19" cy="19" r="1" fill="currentColor" stroke="none"
          ></circle>
        </svg>
        <span class="text-sm">Minor dots</span>
        <span
          aria-hidden="true"
          class="relative ml-auto h-5 w-9 rounded-full bg-zinc-600 transition-colors group-data-[active=true]:bg-cyan-400"
        >
          <span
            class="absolute left-0.5 top-0.5 size-4 rounded-full bg-white shadow-sm transition-transform group-data-[active=true]:translate-x-4"
          ></span>
        </span>
      </button>
    </section>
  </div>

  <p
    id="race-status"
    data-role="race-status"
    class="mt-auto pt-3 text-xs text-zinc-400"
  >
    Ready to race
  </p>
</aside>
