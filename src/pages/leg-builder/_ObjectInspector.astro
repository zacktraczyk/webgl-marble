<section
  id="object-inspector"
  data-role="object-inspector"
  aria-label="Selected object properties"
  hidden
  class="mt-9"
>
  <div class="flex items-center justify-between gap-3">
    <div>
      <p
        class="text-[10px] font-semibold uppercase tracking-widest text-zinc-500"
      >
        Selected object
      </p>
      <h2
        id="object-inspector-title"
        data-role="object-inspector-title"
        class="mt-0.5 text-sm font-medium text-zinc-100"
      >
        Wall
      </h2>
      <p data-role="selection-count" class="mt-0.5 text-[10px] text-zinc-500">
      </p>
    </div>
    <span
      data-role="object-kind-badge"
      class="rounded-full bg-cyan-400/15 px-2 py-1 text-[10px] font-medium text-cyan-200"
    >
      Object
    </span>
  </div>

  <div
    data-role="transform-controls"
    class="mt-3 border-t border-zinc-700 pt-3"
  >
    <p
      class="mb-2 text-[10px] font-semibold uppercase tracking-widest text-zinc-500"
    >
      Transform
    </p>
    <p class="mb-1 text-[10px] text-zinc-500">Position</p>
    <div class="grid grid-cols-2 gap-2">
      <label class="relative" for="transform-x">
        <span
          aria-hidden="true"
          class="pointer-events-none absolute inset-y-0 left-2 flex items-center font-mono text-[11px] text-zinc-500"
          >X</span
        >
        <input
          id="transform-x"
          data-role="transform-x"
          aria-label="X position"
          type="number"
          step="1"
          class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-6 pr-2 font-mono text-xs text-zinc-100 outline-none focus:border-cyan-400"
        />
      </label>
      <label class="relative" for="transform-y">
        <span
          aria-hidden="true"
          class="pointer-events-none absolute inset-y-0 left-2 flex items-center font-mono text-[11px] text-zinc-500"
          >Y</span
        >
        <input
          id="transform-y"
          data-role="transform-y"
          aria-label="Y position"
          type="number"
          step="1"
          class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-6 pr-2 font-mono text-xs text-zinc-100 outline-none focus:border-cyan-400"
        />
      </label>
    </div>

    <div class="mt-3 grid grid-cols-2 gap-2">
      <label class="text-[10px] text-zinc-500" for="transform-primary">
        <span data-role="transform-primary-label">Length</span>
        <input
          id="transform-primary"
          data-role="transform-primary"
          type="number"
          min="1"
          step="1"
          class="mt-1 w-full rounded-md border border-zinc-600 bg-zinc-900 px-2 py-1.5 font-mono text-xs text-zinc-100 outline-none focus:border-cyan-400"
        />
      </label>
      <label
        data-role="transform-secondary-row"
        class="text-[10px] text-zinc-500"
        for="transform-secondary"
      >
        <span data-role="transform-secondary-label">Thickness</span>
        <input
          id="transform-secondary"
          data-role="transform-secondary"
          type="number"
          min="1"
          step="1"
          class="mt-1 w-full rounded-md border border-zinc-600 bg-zinc-900 px-2 py-1.5 font-mono text-xs text-zinc-100 outline-none focus:border-cyan-400"
        />
      </label>
    </div>

    <p class="mb-1 mt-3 text-[10px] text-zinc-500">Rotation</p>
    <div class="flex gap-2">
      <label class="relative min-w-0 flex-1" for="transform-rotation">
        <span
          aria-hidden="true"
          class="pointer-events-none absolute inset-y-0 left-2 flex items-center text-zinc-500"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path d="M5 17V8"></path>
            <path d="M5 17h10"></path>
            <path d="M5 12a5 5 0 0 1 5 5"></path>
          </svg>
        </span>
        <input
          id="transform-rotation"
          data-role="transform-rotation"
          aria-label="Rotation in degrees"
          type="number"
          step="1"
          class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-8 pr-2 font-mono text-xs text-zinc-100 outline-none focus:border-cyan-400"
        />
      </label>

      <div
        class="flex shrink-0 overflow-hidden rounded-md border border-zinc-600"
      >
        <button
          data-transform-action="rotate-clockwise"
          data-tooltip="Rotate 90° clockwise"
          aria-label="Rotate 90 degrees clockwise"
          type="button"
          class="flex h-7 w-8 items-center justify-center text-zinc-300 outline-none hover:bg-zinc-700 hover:text-white focus-visible:bg-zinc-700 focus-visible:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-3.5"
            aria-hidden="true"
          >
            <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"></path>
            <path d="M21 3v5h-5"></path>
          </svg>
        </button>
        <button
          data-transform-action="flip-left-right"
          data-tooltip="Flip left ↔ right"
          aria-label="Flip left to right"
          type="button"
          class="flex h-7 w-8 items-center justify-center border-x border-zinc-600 text-zinc-300 outline-none hover:bg-zinc-700 hover:text-white focus-visible:bg-zinc-700 focus-visible:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-3.5"
            aria-hidden="true"
          >
            <path d="m3 7 5 5-5 5V7"></path>
            <path d="m21 7-5 5 5 5V7"></path>
            <path d="M12 20v2"></path>
            <path d="M12 14v2"></path>
            <path d="M12 8v2"></path>
            <path d="M12 2v2"></path>
          </svg>
        </button>
        <button
          data-transform-action="flip-top-bottom"
          data-tooltip="Flip top ↕ bottom"
          aria-label="Flip top to bottom"
          type="button"
          class="flex h-7 w-8 items-center justify-center text-zinc-300 outline-none hover:bg-zinc-700 hover:text-white focus-visible:bg-zinc-700 focus-visible:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-3.5"
            aria-hidden="true"
          >
            <path d="m17 3-5 5-5-5h10"></path>
            <path d="m17 21-5-5-5 5h10"></path>
            <path d="M4 12H2"></path>
            <path d="M10 12H8"></path>
            <path d="M16 12h-2"></path>
            <path d="M22 12h-2"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div
    data-role="multi-selection-controls"
    class="mt-3 border-t border-zinc-700 pt-3"
    hidden
  >
    <p
      class="mb-2 text-[10px] font-semibold uppercase tracking-widest text-zinc-500"
    >
      Arrange
    </p>
    <div class="grid grid-cols-3 gap-1">
      <button
        data-arrange-action="align-left"
        type="button"
        class="rounded border border-zinc-600 px-1 py-1.5 text-[10px] hover:bg-zinc-700"
        >Left</button
      >
      <button
        data-arrange-action="align-center-horizontal"
        type="button"
        class="rounded border border-zinc-600 px-1 py-1.5 text-[10px] hover:bg-zinc-700"
        >Center X</button
      >
      <button
        data-arrange-action="align-right"
        type="button"
        class="rounded border border-zinc-600 px-1 py-1.5 text-[10px] hover:bg-zinc-700"
        >Right</button
      >
      <button
        data-arrange-action="align-top"
        type="button"
        class="rounded border border-zinc-600 px-1 py-1.5 text-[10px] hover:bg-zinc-700"
        >Top</button
      >
      <button
        data-arrange-action="align-center-vertical"
        type="button"
        class="rounded border border-zinc-600 px-1 py-1.5 text-[10px] hover:bg-zinc-700"
        >Center Y</button
      >
      <button
        data-arrange-action="align-bottom"
        type="button"
        class="rounded border border-zinc-600 px-1 py-1.5 text-[10px] hover:bg-zinc-700"
        >Bottom</button
      >
      <button
        data-arrange-action="distribute-horizontal"
        type="button"
        class="col-span-3 rounded border border-zinc-600 px-1 py-1.5 text-[10px] hover:bg-zinc-700"
        >Distribute horizontally</button
      >
      <button
        data-arrange-action="distribute-vertical"
        type="button"
        class="col-span-3 rounded border border-zinc-600 px-1 py-1.5 text-[10px] hover:bg-zinc-700"
        >Distribute vertically</button
      >
    </div>
  </div>

  <div data-role="motion-inspector" class="mt-3 border-y border-zinc-700 py-3">
    <label class="block text-xs text-zinc-400" for="motion-type">
      Motion
      <select
        id="motion-type"
        data-role="motion-type"
        class="mt-1.5 w-full rounded-md border border-zinc-600 bg-zinc-900 px-2 py-2 text-xs text-zinc-100 outline-none focus:border-cyan-400"
      >
        <option value="none">None</option>
        <option value="slide">Slide</option>
        <option value="spin">Spin</option>
        <option value="sweep">Sweep from endpoint</option>
      </select>
    </label>

    <div id="motion-controls" data-role="motion-controls" class="mt-3" hidden>
      <div class="flex items-center justify-between gap-3">
        <span class="text-xs text-zinc-400">Speed</span>
        <div class="flex overflow-hidden rounded-md border border-zinc-600">
          <button
            id="motion-speed-slow"
            data-role="motion-speed-slow"
            type="button"
            data-speed="slow"
            data-active="false"
            class="px-2 py-1.5 text-[10px] text-zinc-300 hover:bg-zinc-700 data-[active=true]:bg-cyan-400 data-[active=true]:text-cyan-950"
            >Slow</button
          >
          <button
            id="motion-speed-medium"
            data-role="motion-speed-medium"
            type="button"
            data-speed="medium"
            data-active="true"
            class="border-x border-zinc-600 px-2 py-1.5 text-[10px] text-zinc-300 hover:bg-zinc-700 data-[active=true]:bg-cyan-400 data-[active=true]:text-cyan-950"
            >Medium</button
          >
          <button
            id="motion-speed-fast"
            data-role="motion-speed-fast"
            type="button"
            data-speed="fast"
            data-active="false"
            class="px-2 py-1.5 text-[10px] text-zinc-300 hover:bg-zinc-700 data-[active=true]:bg-cyan-400 data-[active=true]:text-cyan-950"
            >Fast</button
          >
        </div>
      </div>

      <label
        id="motion-range-row"
        data-role="motion-range-row"
        class="mt-3 block text-xs text-zinc-400"
        for="motion-range"
      >
        <span class="flex items-center justify-between">
          <span>Distance each way</span>
          <output
            id="motion-range-output"
            data-role="motion-range-output"
            for="motion-range"
            class="font-mono text-[11px] text-cyan-200">90</output
          >
        </span>
        <input
          id="motion-range"
          data-role="motion-range"
          type="range"
          min="15"
          max="240"
          step="15"
          value="90"
          class="mt-2 w-full accent-cyan-400"
        />
      </label>

      <button
        id="motion-reverse"
        data-role="motion-reverse"
        type="button"
        class="mt-3 flex w-full items-center justify-center gap-2 rounded-md border border-zinc-600 px-3 py-2 text-xs text-zinc-200 hover:border-cyan-400 hover:bg-cyan-400/10"
      >
        <span aria-hidden="true">⇄</span>
        Reverse direction
      </button>
      <p class="mt-2 text-[10px] leading-4 text-zinc-500">
        Drag the blue path handle on a slider to change its direction and
        distance.
      </p>
    </div>
  </div>
</section>
