---
import HomeLink from "../components/HomeLink.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
  <main class="relative size-full overflow-hidden">
    <HomeLink />

    <p
      id="builder-error"
      class="pointer-events-none absolute left-[calc(50%+10rem)] top-24 z-30 -translate-x-1/2 rounded-lg bg-rose-950/90 px-5 py-3 font-mono text-sm text-rose-200 empty:hidden"
    >
    </p>

    <nav
      aria-label="Level tools"
      class="absolute left-[calc(50%+10rem)] top-5 z-20 flex -translate-x-1/2 items-center gap-1 rounded-lg bg-zinc-700 p-2 shadow-lg"
    >
      <button
        id="tool-pan"
        type="button"
        aria-label="Pan and zoom"
        title="Pan and zoom"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-6"
          aria-hidden="true"
        >
          <path d="M18 11V6a2 2 0 0 0-4 0v4"></path>
          <path d="M14 10V4a2 2 0 0 0-4 0v6"></path>
          <path d="M10 10V6a2 2 0 0 0-4 0v8"></path>
          <path
            d="M18 8a2 2 0 0 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-6-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"
          ></path>
        </svg>
      </button>
      <button
        id="tool-pointer"
        type="button"
        aria-label="Select objects"
        title="Select objects"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-6 data-[active=true]:fill-white"
          aria-hidden="true"
        >
          <path d="m12.6 12.6 6.4 6.4"></path>
          <path
            d="M3.7 3a.5.5 0 0 0-.66.65l6.5 16a.5.5 0 0 0 .95-.06l1.57-6.08a2 2 0 0 1 1.49-1.48l6.08-1.57a.5.5 0 0 0 .06-.95z"
          ></path>
        </svg>
      </button>
      <span class="mx-1 h-6 w-px bg-zinc-600" aria-hidden="true"></span>
      <button
        id="tool-wall"
        type="button"
        aria-label="Place a wall"
        title="Place a wall"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-6"
          aria-hidden="true"
        >
          <rect x="3" y="5" width="18" height="14" rx="1"></rect>
        </svg>
      </button>
      <button
        id="tool-bumper"
        type="button"
        aria-label="Place a circular bumper"
        title="Place a circular bumper"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="size-6"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="9"></circle>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      </button>
      <button
        id="tool-staging-rack"
        type="button"
        aria-label="Move the start rack"
        title="Move the fixed-size staging rack"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-6"
          aria-hidden="true"
        >
          <rect x="2" y="6" width="20" height="12" rx="1"></rect>
          <path d="M7 6v12M12 6v12M17 6v12"></path>
        </svg>
      </button>
      <button
        id="tool-spawn-point"
        type="button"
        aria-label="Move the spawn point"
        title="Move the marble spawn point"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-6"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v4M12 18v4M2 12h4M18 12h4"></path>
        </svg>
      </button>
    </nav>

    <aside
      class="absolute left-5 top-24 z-20 w-72 rounded-xl border border-zinc-700/80 bg-zinc-900/90 p-5 shadow-xl backdrop-blur"
    >
      <div class="mb-5">
        <p
          class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400"
        >
          Round preview
        </p>
        <h1 class="mt-1 text-xl font-semibold">Staging setup</h1>
        <p class="mt-1 text-sm leading-5 text-zinc-400">
          The course stays fixed while teams and marbles change each round.
        </p>
      </div>

      <div class="space-y-5">
        <label class="block text-sm text-zinc-300" for="team-count">
          <span class="mb-2 flex justify-between">
            <span>Teams</span>
            <output id="team-count-output" for="team-count">6</output>
          </span>
          <input
            id="team-count"
            class="w-full accent-cyan-500"
            type="range"
            min="1"
            max="12"
            value="6"
          />
        </label>

        <label class="block text-sm text-zinc-300" for="marbles-per-team">
          <span class="mb-2 flex justify-between">
            <span>Marbles per team</span>
            <output id="marbles-per-team-output" for="marbles-per-team"
              >8</output
            >
          </span>
          <input
            id="marbles-per-team"
            class="w-full accent-cyan-500"
            type="range"
            min="1"
            max="100"
            value="8"
          />
        </label>

        <label class="block text-sm text-zinc-300" for="release-interval">
          <span class="mb-2 flex justify-between">
            <span>Release interval</span>
            <output id="release-interval-output" for="release-interval"
              >140 ms</output
            >
          </span>
          <input
            id="release-interval"
            class="w-full accent-cyan-500"
            type="range"
            min="50"
            max="1000"
            step="10"
            value="140"
          />
        </label>
      </div>

      <div class="mt-6 grid grid-cols-2 gap-2">
        <button
          id="run-race"
          type="button"
          class="rounded-lg bg-cyan-600 px-3 py-2.5 text-sm font-semibold text-white hover:bg-cyan-500"
        >
          Run race
        </button>
        <button
          id="reset-race"
          type="button"
          class="rounded-lg bg-zinc-700 px-3 py-2.5 text-sm font-semibold text-zinc-100 hover:bg-zinc-600"
        >
          Reset
        </button>
      </div>

      <p id="race-status" class="mt-4 text-sm font-medium text-cyan-300">
        Ready to race
      </p>
      <p class="mt-1 text-xs leading-5 text-zinc-500">
        Placement snaps to a 25-unit grid. The red strip is the automatic finish
        trigger.
      </p>
    </aside>

    <details
      class="absolute bottom-5 right-5 z-20 w-56 rounded-lg border border-zinc-700 bg-zinc-900/85 p-3 text-xs text-zinc-400 backdrop-blur"
    >
      <summary class="cursor-pointer select-none font-medium text-zinc-300">
        Runtime details · <span id="builder-fps">FPS: 0</span>
      </summary>
      <pre id="builder-debug" class="mt-3 overflow-auto font-mono"></pre>
    </details>

    <div class="absolute inset-y-0 left-80 right-0">
      <canvas
        id="gl-canvas"
        class="size-full bg-zinc-950 data-[pointer=pan]:cursor-grab data-[pointer=select]:cursor-default data-[pointer=shape]:cursor-crosshair"
      >
        Canvas not supported
      </canvas>
    </div>
  </main>
</Layout>

<script>
  import { mountScene } from "../engine/runtime/mountScene";
  import createScene from "../scenes/level-builder";

  const byId = (id: string) => document.getElementById(id);
  const errorElement = byId("builder-error");

  try {
    mountScene(
      createScene({
        pan: byId("tool-pan"),
        pointer: byId("tool-pointer"),
        wall: byId("tool-wall"),
        bumper: byId("tool-bumper"),
        stagingRack: byId("tool-staging-rack"),
        spawnPoint: byId("tool-spawn-point"),
        play: byId("run-race"),
        reset: byId("reset-race"),
        teamCount: byId("team-count"),
        teamCountOutput: byId("team-count-output"),
        marblesPerTeam: byId("marbles-per-team"),
        marblesPerTeamOutput: byId("marbles-per-team-output"),
        releaseInterval: byId("release-interval"),
        releaseIntervalOutput: byId("release-interval-output"),
        status: byId("race-status"),
        debugInfo: byId("builder-debug"),
      }),
      {
        showFps: true,
        fpsElement: byId("builder-fps"),
        errorElement,
      }
    );
  } catch (error) {
    if (errorElement) {
      errorElement.textContent = `${error}`;
    }
  }
</script>
