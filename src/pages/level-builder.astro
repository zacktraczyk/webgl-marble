---
import HomeLink from "../components/HomeLink.astro";
import Layout from "../layouts/Layout.astro";
import {
  MAX_STAGE_HEIGHT,
  MAX_STAGE_WIDTH,
  MIN_STAGE_HEIGHT,
  MIN_STAGE_WIDTH,
  STAGE_HEIGHT,
  STAGE_SIZE_STEP,
  STAGE_WIDTH,
} from "../scenes/level-builder/constants";
import "../styles/global.css";
---

<Layout>
  <main
    id="level-builder"
    data-sidebar-open="false"
    class="relative size-full overflow-hidden"
  >
    <HomeLink />

    <p
      id="builder-error"
      class="pointer-events-none absolute left-1/2 top-16 z-30 -translate-x-1/2 rounded-md border border-rose-900 bg-rose-950/90 px-3 py-2 font-mono text-xs text-rose-200 shadow-lg backdrop-blur empty:hidden"
    >
    </p>

    <nav
      id="builder-toolbar"
      aria-label="Level tools"
      class="absolute left-1/2 top-3 z-20 flex -translate-x-1/2 items-center gap-1 rounded-lg border border-zinc-700 bg-zinc-800/90 p-1 shadow-lg backdrop-blur"
    >
      <button
        id="tool-pan"
        type="button"
        aria-label="Pan and zoom"
        title="Pan and zoom"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M18 11V6a2 2 0 0 0-4 0v4"></path>
          <path d="M14 10V4a2 2 0 0 0-4 0v6"></path>
          <path d="M10 10V6a2 2 0 0 0-4 0v8"></path>
          <path
            d="M18 8a2 2 0 0 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-6-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"
          ></path>
        </svg>
      </button>
      <button
        id="tool-pointer"
        type="button"
        aria-label="Select objects"
        title="Select objects"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5 data-[active=true]:fill-white"
          aria-hidden="true"
        >
          <path d="m12.6 12.6 6.4 6.4"></path>
          <path
            d="M3.7 3a.5.5 0 0 0-.66.65l6.5 16a.5.5 0 0 0 .95-.06l1.57-6.08a2 2 0 0 1 1.49-1.48l6.08-1.57a.5.5 0 0 0 .06-.95z"
          ></path>
        </svg>
      </button>
      <span class="mx-1 h-5 w-px bg-zinc-600" aria-hidden="true"></span>
      <button
        id="tool-wall"
        type="button"
        aria-label="Place a wall"
        title="Place a wall"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <rect x="3" y="5" width="18" height="14" rx="1"></rect>
        </svg>
      </button>
      <button
        id="tool-bumper"
        type="button"
        aria-label="Place a circular bumper"
        title="Place a circular bumper"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="size-5"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="9"></circle>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      </button>
      <button
        id="tool-spawn-point"
        type="button"
        aria-label="Move the spawn point"
        title="Move the marble spawn point"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v4M12 18v4M2 12h4M18 12h4"></path>
        </svg>
      </button>
    </nav>

    <nav
      aria-label="Viewport zoom"
      class="absolute bottom-3 left-3 z-20 flex items-center gap-1 rounded-lg border border-zinc-700 bg-zinc-800/90 p-1 shadow-lg backdrop-blur"
    >
      <button
        id="zoom-out"
        type="button"
        aria-label="Zoom out"
        title="Zoom out"
        class="flex size-9 items-center justify-center rounded-md text-zinc-100 hover:bg-zinc-700 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:hover:bg-transparent"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
        </svg>
      </button>
      <button
        id="zoom-reset"
        type="button"
        aria-label="Reset zoom to 100%"
        title="Reset zoom to 100%"
        class="flex h-9 min-w-12 items-center justify-center rounded-md px-1 text-center font-mono text-xs text-zinc-300"
      >
        <output id="zoom-level" aria-live="polite">100%</output>
      </button>
      <button
        id="zoom-in"
        type="button"
        aria-label="Zoom in"
        title="Zoom in"
        class="flex size-9 items-center justify-center rounded-md text-zinc-100 hover:bg-zinc-700 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:hover:bg-transparent"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M12 5v14M5 12h14"></path>
        </svg>
      </button>
    </nav>

    <nav
      aria-label="Race controls"
      class="absolute bottom-3 left-1/2 z-20 flex -translate-x-1/2 items-center gap-3 rounded-lg border border-zinc-700 bg-zinc-800/90 p-1 shadow-lg backdrop-blur"
    >
      <button
        id="run-race"
        type="button"
        aria-label="Run race"
        title="Run race"
        data-previewing="false"
        class="flex size-9 items-center justify-center rounded-md bg-green-400 text-green-950 hover:bg-green-300 data-[previewing=true]:bg-red-300 data-[previewing=true]:text-red-950 data-[previewing=true]:hover:bg-red-200 disabled:cursor-not-allowed disabled:bg-zinc-600 disabled:text-zinc-400 disabled:hover:bg-zinc-600"
      >
        <svg
          data-race-icon="play"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M8 5v14l11-7z"></path>
        </svg>
        <svg
          data-race-icon="pause"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="hidden size-5"
          aria-hidden="true"
        >
          <path d="M6 5h4v14H6zM14 5h4v14h-4z"></path>
        </svg>
        <svg
          data-race-icon="replay"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden size-5"
          aria-hidden="true"
        >
          <path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path>
          <path d="M3 3v5h5"></path>
        </svg>
        <span data-race-button-label class="sr-only">Run race</span>
      </button>
      <button
        id="reset-race"
        type="button"
        aria-label="Reset race"
        title="Reset race"
        class="flex size-9 items-center justify-center rounded-md text-zinc-100 hover:bg-zinc-700"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path>
          <path d="M3 3v5h5"></path>
        </svg>
      </button>
    </nav>

    <button
      id="toggle-sidebar"
      type="button"
      aria-controls="level-options-sidebar"
      aria-expanded="false"
      aria-label="Open options sidebar"
      title="Open options sidebar"
      class="absolute right-3 top-3 z-30 flex size-9 items-center justify-center rounded-md border border-zinc-700 bg-zinc-800 text-zinc-200 shadow-lg hover:bg-zinc-700 hover:text-white"
    >
      <svg
        data-sidebar-icon="open"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-5"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="2"></rect>
        <path d="M15 3v18"></path>
      </svg>
      <svg
        data-sidebar-icon="close"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden size-5"
        aria-hidden="true"
      >
        <path d="m18 6-12 12M6 6l12 12"></path>
      </svg>
    </button>

    <aside
      id="level-options-sidebar"
      aria-label="Level options"
      aria-hidden="true"
      inert
      class="absolute inset-y-0 right-0 z-20 flex w-64 flex-col overflow-y-auto border-l border-zinc-700 bg-zinc-800 p-4 transition-transform duration-200"
    >
      <h1 class="pr-10 text-sm font-medium text-zinc-100">Level options</h1>

      <div class="mt-4 divide-y divide-zinc-700">
        <button
          id="toggle-major-grid"
          type="button"
          role="switch"
          aria-checked="true"
          data-active="true"
          class="group flex w-full items-center gap-3 py-3 text-left text-zinc-300 hover:text-zinc-100"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="size-5 shrink-0"
            aria-hidden="true"
          >
            <path d="M4 4h16v16H4zM12 4v16M4 12h16"></path>
          </svg>
          <span class="text-sm">Major grid lines</span>
          <span
            aria-hidden="true"
            class="relative ml-auto h-5 w-9 rounded-full bg-zinc-600 transition-colors group-data-[active=true]:bg-cyan-500"
          >
            <span
              class="absolute left-0.5 top-0.5 size-4 rounded-full bg-white shadow-sm transition-transform group-data-[active=true]:translate-x-4"
            ></span>
          </span>
        </button>

        <button
          id="toggle-minor-grid"
          type="button"
          role="switch"
          aria-checked="false"
          data-active="false"
          class="group flex w-full items-center gap-3 py-3 text-left text-zinc-300 hover:text-zinc-100"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="size-5 shrink-0"
            aria-hidden="true"
          >
            <path d="M4 4h16v16H4zM9.33 4v16M14.67 4v16M4 9.33h16M4 14.67h16"
            ></path>
          </svg>
          <span class="text-sm">Minor grid lines</span>
          <span
            aria-hidden="true"
            class="relative ml-auto h-5 w-9 rounded-full bg-zinc-600 transition-colors group-data-[active=true]:bg-cyan-500"
          >
            <span
              class="absolute left-0.5 top-0.5 size-4 rounded-full bg-white shadow-sm transition-transform group-data-[active=true]:translate-x-4"
            ></span>
          </span>
        </button>

        <div class="py-4">
          <p class="mb-3 text-xs font-medium text-zinc-300">Course size</p>
          <div class="grid grid-cols-2 gap-2">
            <label class="relative" for="course-width">
              <span class="sr-only">Course width</span>
              <span
                aria-hidden="true"
                class="pointer-events-none absolute inset-y-0 left-2 flex items-center font-mono text-[11px] text-zinc-500"
                >W</span
              >
              <input
                id="course-width"
                type="number"
                min={MIN_STAGE_WIDTH}
                max={MAX_STAGE_WIDTH}
                step={STAGE_SIZE_STEP}
                value={STAGE_WIDTH}
                class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-6 pr-2 font-mono text-xs text-zinc-200 outline-none focus:border-cyan-500"
              />
            </label>
            <label class="relative" for="course-height">
              <span class="sr-only">Course height</span>
              <span
                aria-hidden="true"
                class="pointer-events-none absolute inset-y-0 left-2 flex items-center font-mono text-[11px] text-zinc-500"
                >H</span
              >
              <input
                id="course-height"
                type="number"
                min={MIN_STAGE_HEIGHT}
                max={MAX_STAGE_HEIGHT}
                step={STAGE_SIZE_STEP}
                value={STAGE_HEIGHT}
                class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-6 pr-2 font-mono text-xs text-zinc-200 outline-none focus:border-cyan-500"
              />
            </label>
          </div>
        </div>

        <label
          class="flex items-center gap-3 py-3 text-zinc-300"
          for="team-count"
          title="Teams"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5 shrink-0"
            aria-hidden="true"
          >
            <circle cx="8" cy="8" r="3"></circle>
            <circle cx="17" cy="9" r="2"></circle>
            <path d="M3 20v-2a5 5 0 0 1 10 0v2M14 15a4 4 0 0 1 7 3v2"></path>
          </svg>
          <span class="sr-only">Teams</span>
          <input
            id="team-count"
            class="min-w-0 flex-1 accent-zinc-100"
            type="range"
            min="1"
            max="12"
            value="12"
          />
          <output
            id="team-count-output"
            class="w-7 text-right font-mono text-xs text-zinc-400"
            for="team-count">12</output
          >
        </label>

        <label
          class="flex items-center gap-3 py-3 text-zinc-300"
          for="marbles-per-team"
          title="Marbles per team"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="size-5 shrink-0"
            aria-hidden="true"
          >
            <circle cx="8" cy="8" r="3"></circle>
            <circle cx="16" cy="8" r="3"></circle>
            <circle cx="12" cy="16" r="3"></circle>
          </svg>
          <span class="sr-only">Marbles per team</span>
          <input
            id="marbles-per-team"
            class="min-w-0 flex-1 accent-zinc-100"
            type="range"
            min="1"
            max="100"
            value="100"
          />
          <output
            id="marbles-per-team-output"
            class="w-7 text-right font-mono text-xs text-zinc-400"
            for="marbles-per-team">100</output
          >
        </label>

        <label
          class="flex items-center gap-3 py-3 text-zinc-300"
          for="release-interval"
          title="Release interval"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5 shrink-0"
            aria-hidden="true"
          >
            <circle cx="12" cy="13" r="8"></circle>
            <path d="M12 9v4l3 2M9 2h6"></path>
          </svg>
          <span class="sr-only">Release interval</span>
          <input
            id="release-interval"
            class="min-w-0 flex-1 accent-zinc-100"
            type="range"
            min="50"
            max="1000"
            step="10"
            value="140"
          />
          <output
            id="release-interval-output"
            class="w-14 text-right font-mono text-xs text-zinc-400"
            for="release-interval">140 ms</output
          >
        </label>
      </div>

      <p id="race-status" class="mt-3 text-xs text-zinc-400">Ready to race</p>
      <p class="mt-2 text-[11px] leading-4 text-zinc-500">
        Select and drag to move. Drag handles to resize or rotate. Hold Alt for
        free transforms; use arrow keys to nudge. Delete removes the selection.
      </p>

      <details
        class="mt-auto border-t border-zinc-700 pt-3 text-xs text-zinc-400"
      >
        <summary class="cursor-pointer select-none font-medium text-zinc-300">
          Runtime details · <span id="builder-fps">FPS: 0</span>
        </summary>
        <pre
          id="builder-debug"
          class="mt-3 max-h-64 overflow-auto font-mono text-[11px]">
        </pre>
      </details>
    </aside>

    <div id="builder-workspace" class="absolute inset-0 overflow-hidden">
      <canvas
        id="gl-canvas"
        class="size-full bg-zinc-950 data-[pointer=pan]:cursor-grab data-[pointer=select]:cursor-default data-[pointer=shape]:cursor-crosshair"
      >
        Canvas not supported
      </canvas>
      <div id="builder-grid" aria-hidden="true"></div>
      <canvas
        id="editor-overlay"
        class="pointer-events-none absolute inset-0 z-10 size-full"
        aria-hidden="true"></canvas>
    </div>
  </main>
</Layout>

<style>
  #builder-grid {
    --grid-step: 25px;
    --grid-major-step: 100px;
    --grid-minor-color: transparent;
    --grid-major-color: transparent;
    position: absolute;
    pointer-events: none;
    box-sizing: border-box;
    border: 1px solid rgb(161 161 170 / 35%);
    background-image:
      linear-gradient(to right, var(--grid-minor-color) 1px, transparent 1px),
      linear-gradient(to bottom, var(--grid-minor-color) 1px, transparent 1px),
      linear-gradient(to right, var(--grid-major-color) 1px, transparent 1px),
      linear-gradient(to bottom, var(--grid-major-color) 1px, transparent 1px);
    background-size:
      var(--grid-step) var(--grid-step),
      var(--grid-step) var(--grid-step),
      var(--grid-major-step) var(--grid-major-step),
      var(--grid-major-step) var(--grid-major-step);
  }

  #builder-grid[data-minor-visible="true"] {
    --grid-minor-color: rgb(161 161 170 / 22%);
  }

  #builder-grid[data-major-visible="true"] {
    --grid-major-color: rgb(34 211 238 / 28%);
  }

  #builder-grid[hidden] {
    display: none;
  }

  #level-builder[data-sidebar-open="false"] #level-options-sidebar {
    transform: translateX(100%);
  }

  @media (prefers-reduced-motion: reduce) {
    #level-options-sidebar {
      transition-duration: 0ms;
    }
  }
</style>

<script>
  import { mountScene } from "../engine/runtime/mountScene";
  import createScene from "../scenes/level-builder";

  const byId = (id: string) => document.getElementById(id);
  const errorElement = byId("builder-error");
  const builder = byId("level-builder");
  const sidebar = byId("level-options-sidebar");
  const sidebarToggle = byId("toggle-sidebar");
  const openSidebarIcon = sidebarToggle?.querySelector<SVGElement>(
    '[data-sidebar-icon="open"]'
  );
  const closeSidebarIcon = sidebarToggle?.querySelector<SVGElement>(
    '[data-sidebar-icon="close"]'
  );

  const setSidebarOpen = (open: boolean) => {
    if (!builder || !sidebar || !sidebarToggle) {
      return;
    }

    builder.dataset.sidebarOpen = `${open}`;
    sidebarToggle.setAttribute("aria-expanded", `${open}`);
    sidebarToggle.setAttribute(
      "aria-label",
      open ? "Close options sidebar" : "Open options sidebar"
    );
    sidebarToggle.title = open
      ? "Close options sidebar"
      : "Open options sidebar";
    sidebar.setAttribute("aria-hidden", `${!open}`);
    sidebar.toggleAttribute("inert", !open);
    openSidebarIcon?.classList.toggle("hidden", open);
    closeSidebarIcon?.classList.toggle("hidden", !open);
  };

  sidebarToggle?.addEventListener("click", () => {
    setSidebarOpen(builder?.dataset.sidebarOpen !== "true");
  });

  try {
    mountScene(
      createScene({
        pan: byId("tool-pan"),
        pointer: byId("tool-pointer"),
        wall: byId("tool-wall"),
        bumper: byId("tool-bumper"),
        spawnPoint: byId("tool-spawn-point"),
        majorGridToggle: byId("toggle-major-grid"),
        minorGridToggle: byId("toggle-minor-grid"),
        gridOverlay: byId("builder-grid"),
        editorOverlay: byId("editor-overlay"),
        play: byId("run-race"),
        reset: byId("reset-race"),
        zoomIn: byId("zoom-in"),
        zoomOut: byId("zoom-out"),
        zoomReset: byId("zoom-reset"),
        zoomLevel: byId("zoom-level"),
        teamCount: byId("team-count"),
        teamCountOutput: byId("team-count-output"),
        marblesPerTeam: byId("marbles-per-team"),
        marblesPerTeamOutput: byId("marbles-per-team-output"),
        releaseInterval: byId("release-interval"),
        releaseIntervalOutput: byId("release-interval-output"),
        courseWidth: byId("course-width"),
        courseHeight: byId("course-height"),
        status: byId("race-status"),
        debugInfo: byId("builder-debug"),
      }),
      {
        showFps: true,
        fpsElement: byId("builder-fps"),
        errorElement,
      }
    );
  } catch (error) {
    if (errorElement) {
      errorElement.textContent = `${error}`;
    }
  }
</script>
