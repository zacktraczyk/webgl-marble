---
import HomeLink from "../components/HomeLink.astro";
import Layout from "../layouts/Layout.astro";
import {
  COURSE_STROKE_WIDTH,
  MAX_STAGE_HEIGHT,
  MAX_STAGE_WIDTH,
  MAX_WALL_THICKNESS,
  MIN_STAGE_HEIGHT,
  MIN_STAGE_WIDTH,
  MIN_WALL_THICKNESS,
  STAGE_HEIGHT,
  STAGE_SIZE_STEP,
  STAGE_WIDTH,
} from "../scenes/level-builder/constants";
import "../styles/global.css";
---

<Layout>
  <main
    id="level-builder"
    data-sidebar-open="false"
    class="relative size-full overflow-hidden"
  >
    <HomeLink />

    <p
      id="builder-error"
      class="pointer-events-none absolute left-1/2 top-24 z-30 -translate-x-1/2 rounded-md border border-rose-900 bg-rose-950/90 px-3 py-2 font-mono text-xs text-rose-200 shadow-lg backdrop-blur empty:hidden"
    >
    </p>

    <nav
      id="builder-toolbar"
      aria-label="Level tools"
      class="absolute left-1/2 top-3 z-30 flex -translate-x-1/2 items-center gap-1 rounded-lg border border-zinc-700 bg-zinc-800/90 p-1 shadow-lg backdrop-blur"
    >
      <button
        id="tool-lock"
        type="button"
        aria-label="Keep drawing is on"
        aria-pressed="true"
        title="Keep drawing is on (Q)"
        data-active="true"
        disabled
        class="flex size-9 items-center justify-center rounded-md text-zinc-200 hover:bg-zinc-600 data-[active=true]:bg-violet-400 data-[active=true]:text-violet-950 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:hover:bg-transparent"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <rect x="5" y="10" width="14" height="10" rx="2"></rect>
          <path d="M8 10V7a4 4 0 0 1 8 0v3"></path>
        </svg>
      </button>
      <span class="mx-1 h-5 w-px bg-zinc-600" aria-hidden="true"></span>
      <button
        id="tool-pan"
        type="button"
        aria-label="Pan and zoom"
        title="Pan and zoom (H)"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M18 11V6a2 2 0 0 0-4 0v4"></path>
          <path d="M14 10V4a2 2 0 0 0-4 0v6"></path>
          <path d="M10 10V6a2 2 0 0 0-4 0v8"></path>
          <path
            d="M18 8a2 2 0 0 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-6-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"
          ></path>
        </svg>
      </button>
      <button
        id="tool-pointer"
        type="button"
        aria-label="Select objects"
        title="Select objects (V)"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:opacity-50 disabled:hover:bg-transparent"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5 data-[active=true]:fill-white"
          aria-hidden="true"
        >
          <path d="m12.6 12.6 6.4 6.4"></path>
          <path
            d="M3.7 3a.5.5 0 0 0-.66.65l6.5 16a.5.5 0 0 0 .95-.06l1.57-6.08a2 2 0 0 1 1.49-1.48l6.08-1.57a.5.5 0 0 0 .06-.95z"
          ></path>
        </svg>
      </button>
      <span class="mx-1 h-5 w-px bg-zinc-600" aria-hidden="true"></span>
      <button
        id="tool-wall"
        type="button"
        aria-label="Place a wall"
        title="Place walls (W or L)"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:opacity-50 disabled:hover:bg-transparent"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M5 18 19 6"></path>
          <circle cx="5" cy="18" r="2" fill="currentColor" stroke="none"
          ></circle>
          <circle cx="19" cy="6" r="2" fill="currentColor" stroke="none"
          ></circle>
        </svg>
      </button>
      <div class="relative">
        <button
          id="tool-pusher-menu"
          type="button"
          aria-label="Open pusher library"
          aria-haspopup="menu"
          aria-expanded="false"
          title="Pushers"
          data-active="false"
          class="flex size-9 items-center justify-center rounded-md text-violet-200 hover:bg-zinc-600 data-[active=true]:bg-violet-400 data-[active=true]:text-violet-950 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:opacity-50 disabled:hover:bg-transparent"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5"
            aria-hidden="true"
          >
            <path d="M4 12h16M7 8l-3 4 3 4M17 8l3 4-3 4"></path>
            <path d="M9 6h6v12H9z"></path>
          </svg>
        </button>
        <div
          id="pusher-library"
          role="menu"
          aria-label="Pusher library"
          hidden
          class="absolute left-1/2 top-12 z-40 w-64 -translate-x-1/2 rounded-lg border border-zinc-700 bg-zinc-800 p-2 text-left shadow-xl"
        >
          <p
            class="px-2 pb-2 pt-1 text-[10px] font-semibold uppercase tracking-widest text-zinc-500"
          >
            Pusher library
          </p>
          <button
            id="tool-slider"
            role="menuitem"
            type="button"
            data-active="false"
            class="group flex w-full items-center gap-3 rounded-md px-2 py-2 text-left hover:bg-zinc-700 data-[active=true]:bg-violet-400/15"
          >
            <span
              class="relative flex h-9 w-14 shrink-0 items-center justify-center rounded bg-zinc-900 text-violet-300"
            >
              <span
                class="absolute h-px w-10 border-t border-dashed border-violet-400"
              ></span>
              <span class="relative h-7 w-2 rounded-sm bg-violet-400"></span>
            </span>
            <span>
              <span class="block text-xs font-medium text-zinc-100">Slider</span
              >
              <span class="block text-[11px] text-zinc-400"
                >Moves back and forth</span
              >
            </span>
          </button>
          <button
            id="tool-spinner"
            role="menuitem"
            type="button"
            data-active="false"
            class="group mt-1 flex w-full items-center gap-3 rounded-md px-2 py-2 text-left hover:bg-zinc-700 data-[active=true]:bg-violet-400/15"
          >
            <span
              class="relative flex h-9 w-14 shrink-0 items-center justify-center rounded bg-zinc-900 text-violet-300"
            >
              <span
                class="absolute size-7 rounded-full border border-dashed border-violet-400"
              ></span>
              <span
                class="relative h-1.5 w-8 rotate-45 rounded-full bg-violet-400"
              ></span>
            </span>
            <span>
              <span class="block text-xs font-medium text-zinc-100"
                >Spinner</span
              >
              <span class="block text-[11px] text-zinc-400"
                >Rotates around its center</span
              >
            </span>
          </button>
          <button
            id="tool-sweeper"
            role="menuitem"
            type="button"
            data-active="false"
            class="group mt-1 flex w-full items-center gap-3 rounded-md px-2 py-2 text-left hover:bg-zinc-700 data-[active=true]:bg-violet-400/15"
          >
            <span
              class="relative flex h-9 w-14 shrink-0 items-center justify-center rounded bg-zinc-900 text-violet-300"
            >
              <span
                class="absolute left-3 size-7 rounded-full border border-dashed border-violet-400"
              ></span>
              <span
                class="relative ml-2 h-1.5 w-8 -rotate-12 rounded-full bg-violet-400"
              ></span>
              <span
                class="absolute left-3 size-1.5 rounded-full bg-zinc-950 ring-1 ring-violet-300"
              ></span>
            </span>
            <span>
              <span class="block text-xs font-medium text-zinc-100"
                >Sweeper</span
              >
              <span class="block text-[11px] text-zinc-400"
                >Pivots from one endpoint</span
              >
            </span>
          </button>
        </div>
      </div>
      <button
        id="tool-spawn-point"
        type="button"
        aria-label="Move the spawn point"
        title="Move the marble spawn point (S)"
        data-active="false"
        class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:opacity-50 disabled:hover:bg-transparent"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v4M12 18v4M2 12h4M18 12h4"></path>
        </svg>
      </button>
    </nav>

    <p
      id="tool-hint"
      aria-live="polite"
      class="pointer-events-none absolute left-1/2 top-16 z-20 -translate-x-1/2 whitespace-nowrap text-center text-xs text-zinc-500"
    >
      Hold <kbd>Space</kbd> and drag to pan
    </p>

    <div class="absolute bottom-3 left-3 z-20 flex h-9 items-stretch gap-2">
      <nav
        aria-label="Viewport zoom"
        class="flex h-9 items-stretch overflow-hidden rounded-md border border-zinc-700 bg-zinc-800/90 shadow-lg backdrop-blur"
      >
        <button
          id="zoom-out"
          type="button"
          aria-label="Zoom out"
          title="Zoom out"
          class="flex w-9 items-center justify-center text-zinc-100 hover:bg-zinc-700 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:hover:bg-transparent"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            class="size-5"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
          </svg>
        </button>
        <button
          id="zoom-reset"
          type="button"
          aria-label="Reset zoom to 100%"
          title="Reset zoom to 100%"
          class="flex min-w-14 items-center justify-center px-2 text-center font-mono text-xs text-zinc-300 hover:bg-zinc-700"
        >
          <output id="zoom-level" aria-live="polite">100%</output>
        </button>
        <button
          id="zoom-in"
          type="button"
          aria-label="Zoom in"
          title="Zoom in"
          class="flex w-9 items-center justify-center text-zinc-100 hover:bg-zinc-700 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:hover:bg-transparent"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            class="size-5"
            aria-hidden="true"
          >
            <path d="M12 5v14M5 12h14"></path>
          </svg>
        </button>
      </nav>

      <nav
        aria-label="Edit history"
        class="flex h-9 items-stretch overflow-hidden rounded-md border border-zinc-700 bg-zinc-800/90 shadow-lg backdrop-blur"
      >
        <button
          id="undo-level"
          type="button"
          aria-label="Undo"
          title="Undo (Ctrl/⌘ Z)"
          disabled
          class="flex w-9 items-center justify-center text-zinc-100 hover:bg-zinc-700 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:hover:bg-transparent"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5"
            aria-hidden="true"
          >
            <path d="M9 7 4 12l5 5"></path>
            <path d="M4 12h9a6 6 0 0 1 6 6"></path>
          </svg>
        </button>
        <button
          id="redo-level"
          type="button"
          aria-label="Redo"
          title="Redo (Ctrl/⌘ Shift Z)"
          disabled
          class="flex w-9 items-center justify-center text-zinc-100 hover:bg-zinc-700 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:hover:bg-transparent"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5"
            aria-hidden="true"
          >
            <path d="m15 7 5 5-5 5"></path>
            <path d="M20 12h-9a6 6 0 0 0-6 6"></path>
          </svg>
        </button>
      </nav>
    </div>

    <nav
      id="builder-race-controls"
      aria-label="Race controls"
      class="absolute bottom-3 left-1/2 z-20 flex -translate-x-1/2 items-center gap-3 rounded-lg border border-zinc-700 bg-zinc-800/90 p-1 shadow-lg backdrop-blur"
    >
      <button
        id="run-race"
        type="button"
        aria-label="Run race"
        title="Run race"
        data-previewing="false"
        class="flex size-9 items-center justify-center rounded-md bg-green-400 text-green-950 hover:bg-green-300 data-[previewing=true]:bg-red-300 data-[previewing=true]:text-red-950 data-[previewing=true]:hover:bg-red-200 disabled:cursor-not-allowed disabled:bg-zinc-600 disabled:text-zinc-400 disabled:hover:bg-zinc-600"
      >
        <svg
          data-race-icon="play"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M8 5v14l11-7z"></path>
        </svg>
        <svg
          data-race-icon="pause"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="hidden size-5"
          aria-hidden="true"
        >
          <path d="M6 5h4v14H6zM14 5h4v14h-4z"></path>
        </svg>
        <svg
          data-race-icon="replay"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden size-5"
          aria-hidden="true"
        >
          <path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path>
          <path d="M3 3v5h5"></path>
        </svg>
        <span data-race-button-label class="sr-only">Run race</span>
      </button>
      <button
        id="reset-race"
        type="button"
        aria-label="Reset race"
        title="Reset race"
        class="flex size-9 items-center justify-center rounded-md text-zinc-100 hover:bg-zinc-700"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path>
          <path d="M3 3v5h5"></path>
        </svg>
      </button>
    </nav>

    <div
      id="race-outcome"
      role="status"
      aria-live="polite"
      aria-atomic="true"
      hidden
      class="pointer-events-none absolute bottom-16 left-1/2 z-20 flex -translate-x-1/2 items-center gap-3 rounded-xl border border-zinc-600 bg-zinc-900/95 px-4 py-2.5 shadow-xl backdrop-blur"
    >
      <span
        data-race-outcome-swatch
        aria-hidden="true"
        class="size-4 shrink-0 rounded-full ring-2 ring-white/25"
      ></span>
      <span>
        <strong
          data-race-outcome-label
          class="block text-sm font-semibold text-zinc-50"
        >Round complete</strong>
        <span class="block text-[11px] text-zinc-400"
          >Final marble · time frozen</span
        >
      </span>
    </div>

    <button
      id="toggle-sidebar"
      type="button"
      aria-controls="level-options-sidebar"
      aria-expanded="false"
      aria-label="Open options sidebar"
      title="Open options sidebar"
      class="absolute right-3 top-3 z-30 flex size-9 items-center justify-center rounded-md border border-zinc-700 bg-zinc-800 text-zinc-200 shadow-lg hover:bg-zinc-700 hover:text-white"
    >
      <svg
        data-sidebar-icon="open"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-5"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="2"></rect>
        <path d="M15 3v18"></path>
      </svg>
      <svg
        data-sidebar-icon="close"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden size-5"
        aria-hidden="true"
      >
        <path d="m18 6-12 12M6 6l12 12"></path>
      </svg>
    </button>

    <section
      id="object-inspector"
      aria-label="Selected wall properties"
      hidden
      class="absolute right-3 top-16 z-20 w-64 rounded-lg border border-zinc-700 bg-zinc-800/95 p-3 shadow-xl backdrop-blur transition-[right] duration-200"
    >
      <div class="flex items-center justify-between gap-3">
        <div>
          <p
            class="text-[10px] font-semibold uppercase tracking-widest text-zinc-500"
          >
            Selected object
          </p>
          <h2
            id="object-inspector-title"
            class="mt-0.5 text-sm font-medium text-zinc-100"
          >
            Wall
          </h2>
        </div>
        <span
          class="rounded-full bg-violet-400/15 px-2 py-1 text-[10px] font-medium text-violet-200"
        >
          Motion
        </span>
      </div>

      <label class="mt-3 block text-xs text-zinc-400" for="motion-type">
        Motion
        <select
          id="motion-type"
          class="mt-1.5 w-full rounded-md border border-zinc-600 bg-zinc-900 px-2 py-2 text-xs text-zinc-100 outline-none focus:border-violet-400"
        >
          <option value="none">None</option>
          <option value="slide">Slide</option>
          <option value="spin">Spin</option>
          <option value="sweep">Sweep from endpoint</option>
        </select>
      </label>

      <div
        id="motion-controls"
        class="mt-3 border-t border-zinc-700 pt-3"
        hidden
      >
        <div class="flex items-center justify-between gap-3">
          <span class="text-xs text-zinc-400">Speed</span>
          <div class="flex overflow-hidden rounded-md border border-zinc-600">
            <button
              id="motion-speed-slow"
              type="button"
              data-speed="slow"
              data-active="false"
              class="px-2 py-1.5 text-[10px] text-zinc-300 hover:bg-zinc-700 data-[active=true]:bg-violet-400 data-[active=true]:text-violet-950"
              >Slow</button
            >
            <button
              id="motion-speed-medium"
              type="button"
              data-speed="medium"
              data-active="true"
              class="border-x border-zinc-600 px-2 py-1.5 text-[10px] text-zinc-300 hover:bg-zinc-700 data-[active=true]:bg-violet-400 data-[active=true]:text-violet-950"
              >Medium</button
            >
            <button
              id="motion-speed-fast"
              type="button"
              data-speed="fast"
              data-active="false"
              class="px-2 py-1.5 text-[10px] text-zinc-300 hover:bg-zinc-700 data-[active=true]:bg-violet-400 data-[active=true]:text-violet-950"
              >Fast</button
            >
          </div>
        </div>

        <label
          id="motion-range-row"
          class="mt-3 block text-xs text-zinc-400"
          for="motion-range"
        >
          <span class="flex items-center justify-between">
            <span>Distance each way</span>
            <output
              id="motion-range-output"
              for="motion-range"
              class="font-mono text-[11px] text-violet-200">90</output
            >
          </span>
          <input
            id="motion-range"
            type="range"
            min="15"
            max="240"
            step="15"
            value="90"
            class="mt-2 w-full accent-violet-400"
          />
        </label>

        <button
          id="motion-reverse"
          type="button"
          class="mt-3 flex w-full items-center justify-center gap-2 rounded-md border border-zinc-600 px-3 py-2 text-xs text-zinc-200 hover:border-violet-400 hover:bg-violet-400/10"
        >
          <span aria-hidden="true">⇄</span>
          Reverse direction
        </button>
        <p class="mt-2 text-[10px] leading-4 text-zinc-500">
          Drag the violet path handle on a slider to change its direction and
          distance.
        </p>
      </div>
    </section>

    <aside
      id="level-options-sidebar"
      aria-label="Level options"
      aria-hidden="true"
      inert
      class="absolute inset-y-0 right-0 z-20 flex w-64 flex-col overflow-y-auto border-l border-zinc-700 bg-zinc-800 p-4 transition-transform duration-200"
    >
      <h1 class="pr-10 text-sm font-medium text-zinc-100">Level options</h1>

      <div class="mt-4 divide-y divide-zinc-700">
        <div class="py-4">
          <p class="mb-3 text-xs font-medium text-zinc-300">Course size</p>
          <div class="grid grid-cols-2 gap-2">
            <label class="relative" for="course-width">
              <span class="sr-only">Course width</span>
              <span
                aria-hidden="true"
                class="pointer-events-none absolute inset-y-0 left-2 flex items-center font-mono text-[11px] text-zinc-500"
                >W</span
              >
              <input
                id="course-width"
                type="number"
                min={MIN_STAGE_WIDTH}
                max={MAX_STAGE_WIDTH}
                step={STAGE_SIZE_STEP}
                value={STAGE_WIDTH}
                class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-6 pr-2 font-mono text-xs text-zinc-200 outline-none focus:border-cyan-500"
              />
            </label>
            <label class="relative" for="course-height">
              <span class="sr-only">Course height</span>
              <span
                aria-hidden="true"
                class="pointer-events-none absolute inset-y-0 left-2 flex items-center font-mono text-[11px] text-zinc-500"
                >H</span
              >
              <input
                id="course-height"
                type="number"
                min={MIN_STAGE_HEIGHT}
                max={MAX_STAGE_HEIGHT}
                step={STAGE_SIZE_STEP}
                value={STAGE_HEIGHT}
                class="w-full rounded-md border border-zinc-600 bg-zinc-900 py-1.5 pl-6 pr-2 font-mono text-xs text-zinc-200 outline-none focus:border-cyan-500"
              />
            </label>
          </div>
        </div>

        <label
          class="flex items-center gap-3 py-3 text-zinc-300"
          for="wall-thickness"
          title="Default wall thickness"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            class="size-5 shrink-0"
            aria-hidden="true"
          >
            <path d="M4 8h16M4 16h16"></path>
            <path d="M7 5v6M17 13v6"></path>
          </svg>
          <span class="text-sm">Wall thickness</span>
          <input
            id="wall-thickness"
            type="number"
            min={MIN_WALL_THICKNESS}
            max={MAX_WALL_THICKNESS}
            step="1"
            value={COURSE_STROKE_WIDTH}
            class="ml-auto w-16 rounded-md border border-zinc-600 bg-zinc-900 px-2 py-1.5 text-right font-mono text-xs text-zinc-200 outline-none focus:border-cyan-500"
          />
        </label>

        <section aria-labelledby="spawn-settings-heading" class="py-3">
          <h2
            id="spawn-settings-heading"
            class="mb-1 text-xs font-medium text-zinc-400"
          >
            Spawn settings
          </h2>

          <label
            class="flex items-center gap-3 py-2.5 text-zinc-300"
            for="team-count"
            title="Teams"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-5 shrink-0"
              aria-hidden="true"
            >
              <circle cx="8" cy="8" r="3"></circle>
              <circle cx="17" cy="9" r="2"></circle>
              <path d="M3 20v-2a5 5 0 0 1 10 0v2M14 15a4 4 0 0 1 7 3v2"></path>
            </svg>
            <span class="sr-only">Teams</span>
            <input
              id="team-count"
              class="min-w-0 flex-1 accent-zinc-100"
              type="range"
              min="2"
              max="12"
              value="12"
            />
            <output
              id="team-count-output"
              class="w-7 text-right font-mono text-xs text-zinc-400"
              for="team-count">12</output
            >
          </label>

          <label
            class="flex items-center gap-3 py-2.5 text-zinc-300"
            for="marbles-per-team"
            title="Marbles per team"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="size-5 shrink-0"
              aria-hidden="true"
            >
              <circle cx="8" cy="8" r="3"></circle>
              <circle cx="16" cy="8" r="3"></circle>
              <circle cx="12" cy="16" r="3"></circle>
            </svg>
            <span class="sr-only">Marbles per team</span>
            <input
              id="marbles-per-team"
              class="min-w-0 flex-1 accent-zinc-100"
              type="range"
              min="1"
              max="100"
              value="100"
            />
            <output
              id="marbles-per-team-output"
              class="w-7 text-right font-mono text-xs text-zinc-400"
              for="marbles-per-team">100</output
            >
          </label>

          <label
            class="flex items-center gap-3 py-2.5 text-zinc-300"
            for="release-interval"
            title="Release interval"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-5 shrink-0"
              aria-hidden="true"
            >
              <circle cx="12" cy="13" r="8"></circle>
              <path d="M12 9v4l3 2M9 2h6"></path>
            </svg>
            <span class="sr-only">Release interval</span>
            <input
              id="release-interval"
              class="min-w-0 flex-1 accent-zinc-100"
              type="range"
              min="10"
              max="250"
              step="10"
              value="20"
            />
            <output
              id="release-interval-output"
              class="w-14 text-right font-mono text-xs text-zinc-400"
              for="release-interval">20 ms</output
            >
          </label>
        </section>

        <section
          aria-labelledby="grid-options-heading"
          class="border-b border-zinc-700 py-3"
        >
          <h2
            id="grid-options-heading"
            class="mb-1 text-xs font-medium text-zinc-400"
          >
            Grid
          </h2>

          <button
            id="toggle-grid-snap"
            type="button"
            role="switch"
            aria-checked="true"
            data-active="true"
            class="group flex w-full items-center gap-3 py-2.5 text-left text-zinc-300 hover:text-zinc-100"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-5 shrink-0"
              aria-hidden="true"
            >
              <path d="M8 4H4v4M16 4h4v4M8 20H4v-4M16 20h4v-4"></path>
              <path d="M12 8v8M8 12h8"></path>
            </svg>
            <span class="text-sm">Snap to grid</span>
            <span
              aria-hidden="true"
              class="relative ml-auto h-5 w-9 rounded-full bg-zinc-600 transition-colors group-data-[active=true]:bg-cyan-500"
            >
              <span
                class="absolute left-0.5 top-0.5 size-4 rounded-full bg-white shadow-sm transition-transform group-data-[active=true]:translate-x-4"
              ></span>
            </span>
          </button>

          <button
            id="toggle-major-grid"
            type="button"
            role="switch"
            aria-checked="true"
            data-active="true"
            class="group flex w-full items-center gap-3 py-2.5 text-left text-zinc-300 hover:text-zinc-100"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="size-5 shrink-0"
              aria-hidden="true"
            >
              <path d="M4 4h16v16H4zM12 4v16M4 12h16"></path>
            </svg>
            <span class="text-sm">Major grid lines</span>
            <span
              aria-hidden="true"
              class="relative ml-auto h-5 w-9 rounded-full bg-zinc-600 transition-colors group-data-[active=true]:bg-cyan-500"
            >
              <span
                class="absolute left-0.5 top-0.5 size-4 rounded-full bg-white shadow-sm transition-transform group-data-[active=true]:translate-x-4"
              ></span>
            </span>
          </button>

          <button
            id="toggle-minor-grid"
            type="button"
            role="switch"
            aria-checked="false"
            data-active="false"
            class="group flex w-full items-center gap-3 py-2.5 text-left text-zinc-300 hover:text-zinc-100"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="size-5 shrink-0"
              aria-hidden="true"
            >
              <path d="M4 4h16v16H4zM9.33 4v16M14.67 4v16M4 9.33h16M4 14.67h16"
              ></path>
            </svg>
            <span class="text-sm">Minor grid lines</span>
            <span
              aria-hidden="true"
              class="relative ml-auto h-5 w-9 rounded-full bg-zinc-600 transition-colors group-data-[active=true]:bg-cyan-500"
            >
              <span
                class="absolute left-0.5 top-0.5 size-4 rounded-full bg-white shadow-sm transition-transform group-data-[active=true]:translate-x-4"
              ></span>
            </span>
          </button>
        </section>
      </div>

      <p id="race-status" class="mt-3 text-xs text-zinc-400">Ready to race</p>
      <details
        class="mt-auto border-t border-zinc-700 pt-3 text-xs text-zinc-400"
      >
        <summary class="cursor-pointer select-none font-medium text-zinc-300">
          Runtime details · <span id="builder-fps">FPS: 0</span>
        </summary>
        <pre
          id="builder-debug"
          class="mt-3 max-h-64 overflow-auto font-mono text-[11px]">
        </pre>
      </details>
    </aside>

    <div id="builder-workspace" class="absolute inset-0 overflow-hidden">
      <canvas
        id="gl-canvas"
        class="size-full bg-zinc-900 data-[pointer=pan]:cursor-grab data-[pointer=select]:cursor-default data-[pointer=shape]:cursor-crosshair"
      >
        Canvas not supported
      </canvas>
      <div id="builder-grid" aria-hidden="true"></div>
      <canvas
        id="editor-overlay"
        class="pointer-events-none absolute inset-0 z-10 size-full"
        aria-hidden="true"></canvas>
    </div>
  </main>
</Layout>

<style>
  #builder-grid {
    --grid-step: 15px;
    --grid-major-step: 30px;
    --grid-minor-offset-x: 0px;
    --grid-minor-offset-y: 0px;
    --grid-major-offset-x: 0px;
    --grid-major-offset-y: 0px;
    --grid-minor-color: transparent;
    --grid-major-color: transparent;
    position: absolute;
    pointer-events: none;
    box-sizing: border-box;
    border: 1px solid rgb(161 161 170 / 35%);
    background-image:
      linear-gradient(to right, var(--grid-minor-color) 1px, transparent 1px),
      linear-gradient(to bottom, var(--grid-minor-color) 1px, transparent 1px),
      linear-gradient(to right, var(--grid-major-color) 1px, transparent 1px),
      linear-gradient(to bottom, var(--grid-major-color) 1px, transparent 1px);
    background-size:
      var(--grid-step) var(--grid-step),
      var(--grid-step) var(--grid-step),
      var(--grid-major-step) var(--grid-major-step),
      var(--grid-major-step) var(--grid-major-step);
    background-position:
      var(--grid-minor-offset-x) 0,
      0 var(--grid-minor-offset-y),
      var(--grid-major-offset-x) 0,
      0 var(--grid-major-offset-y);
  }

  #builder-grid[data-minor-visible="true"] {
    --grid-minor-color: rgb(161 161 170 / 22%);
  }

  #builder-grid[data-major-visible="true"] {
    --grid-major-color: rgb(34 211 238 / 28%);
  }

  #builder-grid[hidden] {
    display: none;
  }

  #tool-hint :global(kbd) {
    --keycap-color: rgb(113 113 122);
    display: inline-flex;
    min-height: 1.15rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--keycap-color);
    border-radius: 0.3rem;
    background: transparent;
    padding: 0 0.25rem;
    color: var(--keycap-color);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    line-height: 1;
  }

  #level-builder[data-sidebar-open="false"] #level-options-sidebar {
    transform: translateX(100%);
  }

  #level-builder[data-sidebar-open="true"] #object-inspector {
    right: 16.75rem;
  }

  #pusher-library[hidden],
  #object-inspector[hidden],
  #motion-controls[hidden],
  #motion-range-row[hidden],
  #race-outcome[hidden] {
    display: none;
  }

  @media (max-width: 720px) {
    #level-builder[data-sidebar-open="true"] #object-inspector {
      right: 0.75rem;
    }

    #level-builder[data-sidebar-open="true"] #object-inspector {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #level-options-sidebar {
      transition-duration: 0ms;
    }
  }
</style>

<script>
  import { mountScene } from "../engine/runtime/mountScene";
  import createScene from "../scenes/level-builder";

  const byId = (id: string) => document.getElementById(id);
  const errorElement = byId("builder-error");
  const builder = byId("level-builder");
  const sidebar = byId("level-options-sidebar");
  const sidebarToggle = byId("toggle-sidebar");
  const openSidebarIcon = sidebarToggle?.querySelector<SVGElement>(
    '[data-sidebar-icon="open"]'
  );
  const closeSidebarIcon = sidebarToggle?.querySelector<SVGElement>(
    '[data-sidebar-icon="close"]'
  );

  const setSidebarOpen = (open: boolean) => {
    if (!builder || !sidebar || !sidebarToggle) {
      return;
    }

    builder.dataset.sidebarOpen = `${open}`;
    sidebarToggle.setAttribute("aria-expanded", `${open}`);
    sidebarToggle.setAttribute(
      "aria-label",
      open ? "Close options sidebar" : "Open options sidebar"
    );
    sidebarToggle.title = open
      ? "Close options sidebar"
      : "Open options sidebar";
    sidebar.setAttribute("aria-hidden", `${!open}`);
    sidebar.toggleAttribute("inert", !open);
    openSidebarIcon?.classList.toggle("hidden", open);
    closeSidebarIcon?.classList.toggle("hidden", !open);
  };

  sidebarToggle?.addEventListener("click", () => {
    setSidebarOpen(builder?.dataset.sidebarOpen !== "true");
  });

  try {
    mountScene(
      createScene({
        toolbar: byId("builder-toolbar"),
        raceControls: byId("builder-race-controls"),
        toolLock: byId("tool-lock"),
        toolHint: byId("tool-hint"),
        pan: byId("tool-pan"),
        pointer: byId("tool-pointer"),
        wall: byId("tool-wall"),
        spawnPoint: byId("tool-spawn-point"),
        pusherMenuToggle: byId("tool-pusher-menu"),
        pusherLibrary: byId("pusher-library"),
        slider: byId("tool-slider"),
        spinner: byId("tool-spinner"),
        sweeper: byId("tool-sweeper"),
        gridSnapToggle: byId("toggle-grid-snap"),
        majorGridToggle: byId("toggle-major-grid"),
        minorGridToggle: byId("toggle-minor-grid"),
        gridOverlay: byId("builder-grid"),
        editorOverlay: byId("editor-overlay"),
        play: byId("run-race"),
        reset: byId("reset-race"),
        raceOutcome: byId("race-outcome"),
        zoomIn: byId("zoom-in"),
        zoomOut: byId("zoom-out"),
        zoomReset: byId("zoom-reset"),
        zoomLevel: byId("zoom-level"),
        undo: byId("undo-level"),
        redo: byId("redo-level"),
        teamCount: byId("team-count"),
        teamCountOutput: byId("team-count-output"),
        marblesPerTeam: byId("marbles-per-team"),
        marblesPerTeamOutput: byId("marbles-per-team-output"),
        releaseInterval: byId("release-interval"),
        releaseIntervalOutput: byId("release-interval-output"),
        courseWidth: byId("course-width"),
        courseHeight: byId("course-height"),
        wallThickness: byId("wall-thickness"),
        objectInspector: byId("object-inspector"),
        objectInspectorTitle: byId("object-inspector-title"),
        motionType: byId("motion-type"),
        motionControls: byId("motion-controls"),
        motionRangeRow: byId("motion-range-row"),
        motionRange: byId("motion-range"),
        motionRangeOutput: byId("motion-range-output"),
        motionReverse: byId("motion-reverse"),
        motionSpeedSlow: byId("motion-speed-slow"),
        motionSpeedMedium: byId("motion-speed-medium"),
        motionSpeedFast: byId("motion-speed-fast"),
        status: byId("race-status"),
        debugInfo: byId("builder-debug"),
      }),
      {
        showFps: true,
        fpsElement: byId("builder-fps"),
        errorElement,
      }
    );
  } catch (error) {
    if (errorElement) {
      errorElement.textContent = `${error}`;
    }
  }
</script>
