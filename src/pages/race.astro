---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Race · Marbel">
  <main class="relative size-full overflow-hidden bg-zinc-950">
    <section
      id="race-error-state"
      hidden
      class="absolute inset-0 z-50 grid place-items-center bg-zinc-900 px-5 text-center"
    >
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500"
        >
          Unable to start
        </p>
        <h1
          id="race-error-title"
          class="mt-3 text-2xl font-semibold text-white"
        >
          Race not found
        </h1>
        <p id="race-error-copy" class="mt-3 text-sm text-zinc-400"></p>
        <a
          id="race-error-action"
          href="/"
          class="mt-6 inline-block rounded-md bg-zinc-100 px-4 py-2 text-sm font-semibold text-zinc-900"
          >Return to library</a
        >
      </div>
    </section>

    <section
      id="race-player"
      hidden
      data-race-state="loading"
      data-chrome="hidden"
      class="relative size-full"
    >
      <canvas id="gl-canvas" class="absolute inset-0 size-full bg-zinc-950"
        >Canvas not supported</canvas
      >
      <div id="race-vignette" class="pointer-events-none absolute inset-0">
      </div>

      <div
        id="race-countdown"
        hidden
        aria-hidden="true"
        class="absolute inset-0 z-40 grid select-none place-items-center overflow-hidden"
      >
        <span
          id="race-countdown-value"
          class="font-extrabold tracking-[-0.03em] leading-[0.92]"
        ></span>
      </div>

      <header
        class="pointer-events-none absolute inset-x-0 top-0 z-20 flex items-start justify-between gap-4 p-4 sm:p-6"
      >
        <a
          id="race-back-link"
          href="/race-builder"
          aria-label="Return to race builder"
          class="pointer-events-auto grid size-10 place-items-center rounded-lg border border-zinc-700 bg-zinc-900/80 text-zinc-300 shadow-xl backdrop-blur hover:bg-zinc-800 hover:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-5"
            aria-hidden="true"
          >
            <path d="M19 12H5"></path>
            <path d="m12 19-7-7 7-7"></path>
          </svg>
        </a>

        <div
          id="race-leg-pill"
          class="rounded-lg border border-zinc-700 bg-zinc-900/80 px-4 py-2.5 shadow-xl backdrop-blur"
        >
          <p
            data-role="race-leg-progress"
            class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-200"
          >
          </p>
        </div>
      </header>

      <div
        class="pointer-events-none absolute inset-x-0 top-16 z-30 flex justify-center px-4 sm:top-20"
      >
        <div
          id="elimination-card"
          class="flex items-center gap-3 rounded-full border border-rose-400/25 bg-zinc-950/90 py-2 pl-2 pr-5 shadow-2xl backdrop-blur"
        >
          <span
            class="rounded-full bg-rose-400/15 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.2em] text-rose-300"
          >
            Eliminated
          </span>
          <span
            data-role="race-eliminated"
            class="text-sm font-semibold text-white"
          >
          </span>
        </div>
      </div>

      <div
        class="pointer-events-none absolute inset-0 z-30 grid place-items-center px-5"
      >
        <div
          id="winner-card"
          class="rounded-2xl border border-emerald-300/25 bg-zinc-950/95 px-10 py-9 text-center shadow-2xl backdrop-blur"
        >
          <div
            class="mx-auto grid size-12 place-items-center rounded-full bg-emerald-300 text-lg font-black text-emerald-950"
          >
            1
          </div>
          <p
            class="mt-5 text-[10px] font-bold uppercase tracking-[0.28em] text-emerald-300"
          >
            Winning team
          </p>
          <p
            data-role="race-winner"
            class="mt-2 text-4xl font-semibold tracking-tight text-white"
          >
          </p>
          <div class="pointer-events-auto mt-7 flex justify-center gap-2">
            <button
              data-role="race-restart"
              type="button"
              class="rounded-md border border-zinc-600 px-4 py-2 text-sm font-medium text-zinc-200 hover:bg-zinc-800"
              >Race again</button
            >
            <a
              href="/"
              class="rounded-md bg-zinc-100 px-4 py-2 text-sm font-semibold text-zinc-900 hover:bg-white"
              >Library</a
            >
          </div>
        </div>
      </div>

      <div
        id="race-controls"
        class="pointer-events-none absolute inset-x-0 bottom-4 z-20 flex items-center justify-center gap-2.5 px-4 sm:bottom-6"
      >
        <button
          data-role="race-pause-resume"
          type="button"
          aria-label="Pause race"
          aria-pressed="false"
          class="group pointer-events-auto grid size-12 place-items-center rounded-lg border border-zinc-700 bg-zinc-900/90 text-zinc-100 shadow-xl backdrop-blur hover:bg-zinc-800 hover:text-white disabled:opacity-40"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            class="size-5 group-aria-pressed:hidden"
            aria-hidden="true"
          >
            <path d="M7 5h3.5v14H7zM13.5 5H17v14h-3.5z"></path>
          </svg>
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            class="hidden size-5 group-aria-pressed:block"
            aria-hidden="true"
          >
            <path d="M8.5 5.5v13l10.5-6.5z"></path>
          </svg>
        </button>
        <button
          data-role="race-skip-continue"
          type="button"
          class="pointer-events-auto grid h-12 place-items-center rounded-lg border border-zinc-700 bg-zinc-900/90 px-5 text-sm font-semibold text-zinc-100 shadow-xl backdrop-blur hover:bg-zinc-800 hover:text-white disabled:opacity-40"
          >Skip leg</button
        >
      </div>

      <p
        id="race-error"
        class="pointer-events-none absolute left-1/2 top-24 z-40 -translate-x-1/2 rounded-md bg-rose-950/90 px-3 py-2 text-xs text-rose-200 empty:hidden"
      >
      </p>
    </section>
  </main>
</Layout>

<style>
  /* 3 · 2 · 1 · GO — fullscreen stamped countdown, orange/white/orange */
  #race-countdown {
    --countdown-bg: var(--color-brand);
    --countdown-ink: oklch(97% 0.014 85);
    --countdown-pop: var(--color-brand-shadow);
    --countdown-tilt: 0deg;
    background: var(--countdown-bg);
    opacity: 1;
    transition: opacity 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  #race-countdown[data-step="3"] {
    --countdown-tilt: -2deg;
  }

  #race-countdown[data-step="2"] {
    --countdown-bg: oklch(96% 0.012 85);
    --countdown-ink: var(--color-brand);
    --countdown-tilt: 2.5deg;
  }

  #race-countdown[data-step="1"] {
    --countdown-tilt: -3deg;
  }

  #race-countdown[data-step="go"],
  #race-countdown[data-step="done"] {
    --countdown-bg: oklch(66% 0.2 145);
    --countdown-ink: oklch(97% 0.014 85);
    --countdown-pop: oklch(44% 0.13 148);
  }

  #race-countdown[data-step="done"] {
    opacity: 0;
  }

  #race-countdown-value {
    font-size: clamp(10rem, 58vmin, 34rem);
    line-height: 1;
    color: var(--countdown-ink);
    text-shadow: 0.04em 0.045em 0 var(--countdown-pop);
    transform: rotate(var(--countdown-tilt));
  }

  #race-countdown[data-step="go"] #race-countdown-value,
  #race-countdown[data-step="done"] #race-countdown-value {
    font-size: clamp(7rem, 42vmin, 24rem);
    letter-spacing: -0.02em;
  }

  /* Alternating animation names so each step restarts the stamp */
  #race-countdown[data-step="1"] #race-countdown-value,
  #race-countdown[data-step="3"] #race-countdown-value {
    animation: countdown-stamp-a 460ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  #race-countdown[data-step="2"] #race-countdown-value {
    animation: countdown-stamp-b 460ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  #race-countdown[data-step="go"] #race-countdown-value {
    animation: countdown-burst 520ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes countdown-stamp-a {
    from {
      opacity: 0;
      transform: scale(1.4) rotate(var(--countdown-tilt));
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(var(--countdown-tilt));
    }
  }

  @keyframes countdown-stamp-b {
    from {
      opacity: 0;
      transform: scale(1.4) rotate(var(--countdown-tilt));
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(var(--countdown-tilt));
    }
  }

  @keyframes countdown-burst {
    from {
      opacity: 0;
      transform: scale(0.5);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Edge vignette — top and bottom only, tied to the toolbar chrome so the
     track reads full-bleed once the controls tuck away. */
  #race-vignette {
    background:
      linear-gradient(to bottom, rgb(9 9 11 / 0.55), transparent 22%),
      linear-gradient(to top, rgb(9 9 11 / 0.55), transparent 22%);
    transition: opacity 260ms ease-out;
  }

  #race-player[data-chrome="hidden"] #race-vignette {
    opacity: 0;
  }

  /* Video-player chrome: toolbars slide out on mouse activity and tuck away
     after a beat of stillness — same spring in / ease-in out as the
     leg-builder preview launch. */
  #race-back-link,
  #race-leg-pill,
  #race-controls > * {
    will-change: transform, opacity;
    transition:
      transform 560ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 220ms ease-out;
  }

  #race-player[data-chrome="hidden"] #race-back-link {
    transform: translateX(calc(-100% - 1.5rem)) rotate(-5deg);
  }

  #race-player[data-chrome="hidden"] #race-leg-pill {
    transform: translateY(calc(-100% - 1.5rem)) scale(0.96);
  }

  #race-player[data-chrome="hidden"] #race-controls > :first-child {
    transform: translateY(calc(100% + 1.5rem)) rotate(-4deg);
  }

  #race-player[data-chrome="hidden"] #race-controls > :last-child {
    transform: translateY(calc(100% + 1.5rem)) rotate(4deg);
  }

  #race-player[data-chrome="hidden"] #race-back-link,
  #race-player[data-chrome="hidden"] #race-leg-pill,
  #race-player[data-chrome="hidden"] #race-controls > * {
    pointer-events: none;
    opacity: 0;
    transition-duration: 500ms, 260ms;
    transition-delay: 0ms, 120ms;
    transition-timing-function: cubic-bezier(0.55, 0, 1, 0.45), ease-in;
  }

  #race-player[data-chrome="hidden"] #race-back-link {
    transition-delay: 30ms, 150ms;
  }

  #race-player[data-chrome="hidden"] #race-controls > * {
    transition-delay: 60ms, 180ms;
  }

  #elimination-card {
    opacity: 0;
    transform: translateY(-0.75rem);
    transition:
      opacity 220ms ease,
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #winner-card {
    opacity: 0;
    transform: translateY(1rem) scale(0.96);
    pointer-events: none;
    transition:
      opacity 220ms ease,
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #race-player[data-race-state="transition"] #elimination-card {
    opacity: 1;
    transform: translateY(0);
  }

  #race-player[data-race-state="complete"] #winner-card {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  #race-player[data-race-state="complete"] #winner-card {
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    #elimination-card,
    #winner-card,
    #race-countdown,
    #race-vignette,
    #race-back-link,
    #race-leg-pill,
    #race-controls > * {
      transition-duration: 0ms;
      transition-delay: 0ms;
    }

    #race-countdown-value {
      animation: none !important;
    }
  }
</style>

<script>
  import { mountScene } from "../engine/runtime/mountScene";
  import { RaceRepository, isRacePlayable } from "../races";
  import createRacePlayerScene from "../scenes/race-player";

  const params = new URLSearchParams(window.location.search);
  const raceId = params.get("race") ?? "";
  const repository = new RaceRepository();
  const race = repository.get(raceId);
  const player = document.querySelector<HTMLElement>("#race-player");
  const errorState = document.querySelector<HTMLElement>("#race-error-state");
  const errorTitle = document.querySelector<HTMLElement>("#race-error-title");
  const errorCopy = document.querySelector<HTMLElement>("#race-error-copy");
  const errorAction =
    document.querySelector<HTMLAnchorElement>("#race-error-action");

  const showError = (
    title: string,
    copy: string,
    actionHref = "/",
    actionLabel = "Return to library"
  ) => {
    if (errorState) errorState.hidden = false;
    if (errorTitle) errorTitle.textContent = title;
    if (errorCopy) errorCopy.textContent = copy;
    if (errorAction) {
      errorAction.href = actionHref;
      errorAction.textContent = actionLabel;
    }
  };

  if (!race) {
    showError("Race not found", "It may have been deleted from this browser.");
  } else if (!isRacePlayable(race)) {
    showError(
      "Race setup is incomplete",
      "A race needs exactly one leg for each team that will be eliminated.",
      `/race-builder?race=${encodeURIComponent(race.id)}`,
      "Open race builder"
    );
  } else if (player) {
    const backLink =
      document.querySelector<HTMLAnchorElement>("#race-back-link");
    if (backLink) {
      backLink.href = `/race-builder?race=${encodeURIComponent(race.id)}`;
    }
    player.hidden = false;
    try {
      mountScene(createRacePlayerScene(race, player), {
        errorElement: document.querySelector<HTMLElement>("#race-error"),
      });
      setupChromeAutoHide(player);
    } catch (error) {
      showError("Race could not start", `${error}`);
      player.hidden = true;
    }
  }

  /**
   * Video-player toolbar behavior: mouse activity slides the top/bottom chrome
   * (and edge vignette) out; a beat of stillness tucks it away again. The
   * chrome stays out while a control is hovered or focused, while paused, and
   * on the winner screen.
   */
  function setupChromeAutoHide(root: HTMLElement) {
    const CHROME_HIDE_DELAY_MS = 2600;
    const chrome = [
      "#race-back-link",
      "#race-leg-pill",
      "#race-controls",
    ].flatMap((selector) => [
      ...root.querySelectorAll<HTMLElement>(selector),
    ]);
    let hideTimer: number | undefined;

    const chromeEngaged = () =>
      root.dataset.raceState === "paused" ||
      root.dataset.raceState === "complete" ||
      chrome.some(
        (element) =>
          element.matches(":hover") ||
          element.contains(document.activeElement)
      );

    const hideChrome = () => {
      if (chromeEngaged()) {
        scheduleHide();
        return;
      }
      root.dataset.chrome = "hidden";
    };

    const scheduleHide = () => {
      window.clearTimeout(hideTimer);
      hideTimer = window.setTimeout(hideChrome, CHROME_HIDE_DELAY_MS);
    };

    const showChrome = () => {
      root.dataset.chrome = "visible";
      scheduleHide();
    };

    root.addEventListener("pointermove", showChrome);
    root.addEventListener("pointerdown", showChrome);
    window.addEventListener("keydown", showChrome);
    document.addEventListener("focusin", showChrome);
    root.addEventListener("pointerleave", () => {
      window.clearTimeout(hideTimer);
      hideChrome();
    });

    // Pausing and the winner screen re-reveal the chrome even without mouse
    // movement (e.g. pause via keyboard, race finishing on its own).
    new MutationObserver(() => {
      if (
        root.dataset.raceState === "paused" ||
        root.dataset.raceState === "complete"
      ) {
        showChrome();
      }
    }).observe(root, {
      attributes: true,
      attributeFilter: ["data-race-state"],
    });
  }
</script>
