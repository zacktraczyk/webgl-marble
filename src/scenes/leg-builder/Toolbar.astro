<nav
  id="builder-toolbar"
  data-role="toolbar"
      aria-label="Leg tools"
  class="absolute inset-x-0 top-3 z-30 mx-auto flex w-max items-center gap-1 rounded-lg border border-zinc-700 bg-zinc-800/90 p-1 shadow-lg backdrop-blur"
>
  <button
    id="tool-pan"
    data-role="tool-pan"
    type="button"
    aria-label="Pan and zoom"
    data-tooltip="Pan and zoom (H)"
    data-active="false"
    class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500"
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-5"
      aria-hidden="true"
    >
      <path d="M18 11V6a2 2 0 0 0-4 0v4"></path>
      <path d="M14 10V4a2 2 0 0 0-4 0v6"></path>
      <path d="M10 10V6a2 2 0 0 0-4 0v8"></path>
      <path
        d="M18 8a2 2 0 0 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-6-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"
      ></path>
    </svg>
  </button>
  <button
    id="tool-pointer"
    data-role="tool-pointer"
    type="button"
    aria-label="Select objects"
    data-tooltip="Select objects (V)"
    data-active="false"
    class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:opacity-50 disabled:hover:bg-transparent"
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-5 data-[active=true]:fill-white"
      aria-hidden="true"
    >
      <path d="m12.6 12.6 6.4 6.4"></path>
      <path
        d="M3.7 3a.5.5 0 0 0-.66.65l6.5 16a.5.5 0 0 0 .95-.06l1.57-6.08a2 2 0 0 1 1.49-1.48l6.08-1.57a.5.5 0 0 0 .06-.95z"
      ></path>
    </svg>
  </button>
  <button
    id="tool-wall"
    data-role="tool-wall"
    type="button"
    aria-label="Place a wall"
    data-tooltip="Place walls (W or L)"
    data-active="false"
    class="flex size-9 items-center justify-center rounded-md hover:bg-zinc-600 data-[active=true]:bg-zinc-500 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:opacity-50 disabled:hover:bg-transparent"
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-5"
      aria-hidden="true"
    >
      <path d="M5 18 19 6"></path>
      <circle cx="5" cy="18" r="2" fill="currentColor" stroke="none"></circle>
      <circle cx="19" cy="6" r="2" fill="currentColor" stroke="none"></circle>
    </svg>
  </button>
  <div class="relative">
    <button
      id="tool-pusher-menu"
      data-role="pusher-menu-toggle"
      type="button"
      aria-label="Open pusher library"
      aria-haspopup="menu"
      aria-expanded="false"
      data-tooltip="Pushers"
      data-active="false"
      class="flex size-9 items-center justify-center rounded-md text-white hover:bg-zinc-600 data-[active=true]:bg-zinc-500 disabled:cursor-not-allowed disabled:text-zinc-600 disabled:opacity-50 disabled:hover:bg-transparent"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-5"
        aria-hidden="true"
      >
        <path d="m18 8 4 4-4 4"></path>
        <path d="M2 12h20"></path>
        <path d="m6 8-4 4 4 4"></path>
      </svg>
    </button>
    <div
      id="pusher-library"
      data-role="pusher-library"
      role="menu"
      aria-label="Pusher library"
      hidden
      class="absolute left-1/2 top-12 z-40 w-64 -translate-x-1/2 rounded-lg border border-zinc-700 bg-zinc-800 p-2 text-left shadow-xl"
    >
      <p
        class="px-2 pb-2 pt-1 text-[10px] font-semibold uppercase tracking-widest text-zinc-500"
      >
        Pusher library
      </p>
      <button
        id="tool-slider"
        data-role="tool-slider"
        role="menuitem"
        type="button"
        data-active="false"
        class="group flex w-full items-center gap-3 rounded-md px-2 py-2 text-left hover:bg-zinc-700 data-[active=true]:bg-cyan-400/15"
      >
        <span
          class="relative flex h-9 w-14 shrink-0 items-center justify-center rounded bg-zinc-900 text-cyan-400"
        >
          <span
            class="absolute h-px w-10 border-t border-dashed border-cyan-400"
          ></span>
          <span class="relative h-7 w-2 rounded-sm bg-cyan-400"></span>
        </span>
        <span>
          <span class="block text-xs font-medium text-zinc-100">Slider</span>
          <span class="block text-[11px] text-zinc-400"
            >Moves back and forth</span
          >
        </span>
      </button>
      <button
        id="tool-spinner"
        data-role="tool-spinner"
        role="menuitem"
        type="button"
        data-active="false"
        class="group mt-1 flex w-full items-center gap-3 rounded-md px-2 py-2 text-left hover:bg-zinc-700 data-[active=true]:bg-cyan-400/15"
      >
        <span
          class="relative flex h-9 w-14 shrink-0 items-center justify-center rounded bg-zinc-900 text-cyan-400"
        >
          <span
            class="absolute size-7 rounded-full border border-dashed border-cyan-400"
          ></span>
          <span
            class="relative h-1.5 w-8 rotate-45 rounded-full bg-cyan-400"
          ></span>
        </span>
        <span>
          <span class="block text-xs font-medium text-zinc-100">Spinner</span>
          <span class="block text-[11px] text-zinc-400"
            >Rotates around its center</span
          >
        </span>
      </button>
      <button
        id="tool-sweeper"
        data-role="tool-sweeper"
        role="menuitem"
        type="button"
        data-active="false"
        class="group mt-1 flex w-full items-center gap-3 rounded-md px-2 py-2 text-left hover:bg-zinc-700 data-[active=true]:bg-cyan-400/15"
      >
        <span
          class="relative flex h-9 w-14 shrink-0 items-center justify-center rounded bg-zinc-900 text-cyan-400"
        >
          <span
            class="absolute left-3 size-7 rounded-full border border-dashed border-cyan-400"
          ></span>
          <span
            class="relative ml-2 h-1.5 w-8 -rotate-12 rounded-full bg-cyan-400"
          ></span>
          <span
            class="absolute left-3 size-1.5 rounded-full bg-zinc-950 ring-1 ring-cyan-300"
          ></span>
        </span>
        <span>
          <span class="block text-xs font-medium text-zinc-100">Sweeper</span>
          <span class="block text-[11px] text-zinc-400"
            >Pivots from one endpoint</span
          >
        </span>
      </button>
    </div>
  </div>
</nav>
