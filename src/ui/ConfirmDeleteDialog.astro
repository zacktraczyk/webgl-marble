---
// Shared delete-confirmation dialog, opened via `openConfirmDelete` in
// `confirmDelete.ts`. The name-match field only shows for high-stakes
// deletes (whole races); simple confirms (legs) hide it.
---

<dialog
  id="delete-dialog"
  aria-label="Confirm delete"
  class="dialog-rise m-auto w-[26rem] max-w-[calc(100vw-2.5rem)] rounded-[1.25rem] bg-panel p-7 text-ink shadow-[0_6px_0_var(--color-shadow)] backdrop:bg-black/60"
>
  <form id="delete-form" novalidate>
    <h2
      id="delete-title"
      class="text-[1.375rem] font-extrabold leading-[1.15] tracking-[-0.01em]"
    >
    </h2>
    <p id="delete-message" class="mt-3 text-sm leading-6 text-ink-dim"></p>

    <div id="delete-confirm-field" class="mt-5" hidden>
      <label for="delete-confirm-input" class="block text-sm font-bold text-ink"
        >Type <span id="delete-confirm-name"></span> to confirm</label
      >
      <input
        id="delete-confirm-input"
        type="text"
        autocomplete="off"
        spellcheck="false"
        class="mt-2 block w-full rounded-xl border border-line bg-canvas px-4 py-3 text-sm leading-6 text-ink caret-brand placeholder:text-ink-faint focus:border-ink-dim focus:outline-none"
      />
    </div>

    <div class="mt-7 flex items-center justify-end gap-3">
      <button
        id="delete-cancel"
        type="button"
        class="pill pill-ghost text-sm hover:transform-none">Cancel</button
      >
      <button id="delete-submit" type="submit" class="pill pill-danger text-sm"
        >Delete</button
      >
    </div>
  </form>
</dialog>
