---
// Shared hover tooltip. Render once per page, put `data-tooltip="Label"` (or
// "Label (Shortcut)") on trigger elements, and start it from a script with
// `attachTooltip(document.body)` — see ./tooltip.ts. Layout/static chrome is
// Tailwind; open/side enter animation stays in CSS.
interface Props {
  id?: string;
}

const { id = "app-tooltip" } = Astro.props;
---

<div
  id={id}
  class="tooltip pointer-events-none fixed z-50 flex max-w-72 items-center gap-1.5 whitespace-nowrap rounded-md bg-zinc-50 px-2.5 py-1.5 text-xs font-medium leading-4 text-zinc-950 opacity-0 shadow-[0_0_0_1px_rgb(0_0_0_/_0.1),0_20px_25px_-5px_rgb(0_0_0_/_0.1),0_8px_10px_-6px_rgb(0_0_0_/_0.1)] will-change-[opacity,transform]"
  data-role="tooltip"
  data-side="top"
  data-open="false"
  role="tooltip"
  hidden
>
  <span data-role="tooltip-label"></span>
  <kbd
    data-role="tooltip-shortcut"
    hidden
    class="rounded bg-zinc-200 px-1 py-0.5 font-mono text-[10px] font-semibold leading-none text-zinc-700"
  ></kbd>
  <span
    class="arrow absolute size-2 rotate-45 bg-zinc-50"
    data-role="tooltip-arrow"
    aria-hidden="true"></span>
</div>

<style>
  /* Enter animation depends on data-side / data-open — keep out of Tailwind. */
  .tooltip {
    --tooltip-enter-y: 0.2rem;
    transform: translateY(var(--tooltip-enter-y)) scale(0.96);
    transform-origin: 50% 100%;
    transition:
      opacity 120ms ease-out,
      transform 120ms ease-out;
  }
  .tooltip[hidden] {
    display: none;
  }
  .tooltip[data-side="bottom"] {
    --tooltip-enter-y: -0.2rem;
    transform-origin: 50% 0;
  }
  .tooltip[data-open="true"] {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .tooltip[data-side="top"] .arrow {
    bottom: -0.25rem;
  }
  .tooltip[data-side="bottom"] .arrow {
    top: -0.25rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .tooltip {
      transition-duration: 0ms;
    }
  }
</style>
